    {
      "id": "loginUser",
      "kind": "path",
      "path": "/api/v1/login",
      "method": "post",
      "summary": "Authenticate a user",
      "description": "Authenticate a user with email and password credentials.",
      "deprecated": false,
      "tags": [
        "Authentication"
      ],
      "externalDocs": null,
      "servers": [],
      "security": [],
      "parameters": {
        "path": [],
        "query": [],
        "header": [],
        "cookie": []
      },
      "requestBody": {
        "required": true,
        "description": "Email and password credentials.",
        "content": [
          {
            "mediaType": "application/json",
            "schemaRef": null,
            "schema": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "email",
                "password"
              ],
              "properties": {
                "email": {
                  "type": "string",
                  "format": "email",
                  "description": "User email address.",
                  "example": "admin@example.com"
                },
                "password": {
                  "type": "string",
                  "format": "password",
                  "description": "User password.",
                  "example": "password"
                }
              }
            },
            "examples": [
              {
                "id": "default",
                "summary": "Admin login",
                "description": null,
                "value": {
                  "email": "admin@example.com",
                  "password": "password"
                },
                "externalValue": null
              }
            ],
            "encoding": null
          }
        ]
      },
      "responses": [
        {
          "statusCode": "200",
          "description": "Authenticated user",
          "headers": [],
          "content": [
            {
              "mediaType": "application/json",
              "schemaRef": null,
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "user",
                  "token"
                ],
                "properties": {
                  "user": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "id",
                      "username",
                      "email",
                      "password",
                      "roles"
                    ],
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Unique user identifier.",
                        "example": "9e4e4e91-4c26-4ba2-a2d6-77c5d6d7ce0a"
                      },
                      "username": {
                        "type": "string",
                        "description": "Username displayed for the user.",
                        "example": "admin"
                      },
                      "email": {
                        "type": "string",
                        "format": "email",
                        "description": "Email address used to sign in.",
                        "example": "admin@example.com"
                      },
                      "password": {
                        "type": "string",
                        "format": "password",
                        "description": "User password.",
                        "example": "password"
                      },
                      "roles": {
                        "type": "array",
                        "description": "Roles granted to the user.",
                        "items": {
                          "type": "string",
                          "description": "Role assigned to the authenticated user.",
                          "enum": [
                            "ROLE_SUPER_ADMIN"
                          ]
                        }
                      }
                    }
                  },
                  "token": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "token_type",
                      "expires_in",
                      "access_token"
                    ],
                    "properties": {
                      "token_type": {
                        "type": "string",
                        "description": "Token type returned by the authentication server.",
                        "enum": [
                          "Bearer"
                        ]
                      },
                      "expires_in": {
                        "type": "integer",
                        "format": "int32",
                        "minimum": 0,
                        "description": "Number of seconds before the access token expires.",
                        "example": 3600
                      },
                      "access_token": {
                        "type": "string",
                        "description": "Bearer access token.",
                        "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example"
                      }
                    }
                  }
                }
              },
              "examples": [
                {
                  "id": "default",
                  "summary": "Authenticated user payload",
                  "description": null,
                  "value": {
                    "user": {
                      "id": "9e4e4e91-4c26-4ba2-a2d6-77c5d6d7ce0a",
                      "username": "admin",
                      "email": "admin@example.com",
                      "password": "password",
                      "roles": [
                        "ROLE_SUPER_ADMIN"
                      ]
                    },
                    "token": {
                      "token_type": "Bearer",
                      "expires_in": 3600,
                      "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example"
                    }
                  },
                  "externalValue": null
                }
              ],
              "encoding": null
            }
          ],
          "links": []
        }
      ],
      "callbacks": [],
      "links": [],
      "examples": {
        "request": [
          {
            "mediaType": "application/json",
            "id": "default",
            "summary": "Admin login",
            "value": {
              "email": "admin@example.com",
              "password": "password"
            }
          }
        ],
        "response": [
          {
            "statusCode": "200",
            "mediaType": "application/json",
            "id": "default",
            "summary": "Authenticated user payload",
            "value": {
              "user": {
                "id": "9e4e4e91-4c26-4ba2-a2d6-77c5d6d7ce0a",
                "username": "admin",
                "email": "admin@example.com",
                "password": "password",
                "roles": [
                  "ROLE_SUPER_ADMIN"
                ]
              },
              "token": {
                "token_type": "Bearer",
                "expires_in": 3600,
                "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example"
              }
            }
          }
        ]
      }
    }
