            '</ul>' +
            '</li>';
        }).join('');
      }

      refreshCodeExampleCollections();
      refreshVariantCollections();
      bindCodeExampleInteractions();
      bindVariantInteractions();
      bindTryItInteractions();
      refreshNavigationCollections();
      bindNavigationInteractions();
    }

    function hydrateComponents(renderModel) {
      const groups = renderModel && renderModel.components ? renderModel.components : null;
      if (!groups || !componentsSection || !componentsGrid) {
        return;
      }

      const definitions = [
        { key: 'schemas', label: 'Schemas', itemKind: 'schema' },
        { key: 'requestBodies', label: 'Request Bodies', itemKind: 'requestBody' },
        { key: 'responses', label: 'Responses', itemKind: 'response' },
        { key: 'parameters', label: 'Parameters', itemKind: 'parameter' },
        { key: 'headers', label: 'Headers', itemKind: 'header' },
        { key: 'examples', label: 'Examples', itemKind: 'example' },
        { key: 'securitySchemes', label: 'Security Schemes', itemKind: 'securityScheme' },
        { key: 'links', label: 'Links', itemKind: 'link' },
        { key: 'callbacks', label: 'Callbacks', itemKind: 'callback' }
      ];

      const activeGroups = definitions.map(function (definition) {
        return {
          key: definition.key,
          label: definition.label,
          itemKind: definition.itemKind,
          items: Array.isArray(groups[definition.key]) ? groups[definition.key] : []
        };
      }).filter(function (group) {
        return group.items.length;
      });

      if (!activeGroups.length) {
        return;
      }

      componentsSection.hidden = false;
      if (componentsNavItem) {
        componentsNavItem.hidden = false;
      }

      componentsGrid.innerHTML = activeGroups.map(function (group) {
        const groupId = slugify(group.key);
        return '<section class="component-group">' +
          '<h3 class="anchor" id="components-' + escapeHtml(groupId) + '">' + escapeHtml(group.label) +
          '<a href="#components-' + escapeHtml(groupId) + '" class="hash-link" aria-label="Direct link to ' + escapeHtml(group.label) + '" title="Direct link to ' + escapeHtml(group.label) + '" translate="no">\u200b</a>' +
          '</h3>' +
          '<p class="component-group__meta">' + group.items.length + ' item' + (group.items.length === 1 ? '' : 's') + '</p>' +
          '<div class="component-group__list">' +
          group.items.map(function (item) {
            return renderComponentCard(item, group.itemKind);
          }).join('') +
          '</div>' +
          '</section>';
      }).join('');

      if (componentsNavGroup && componentsNavList) {
        componentsNavGroup.hidden = false;
        componentsNavList.innerHTML = activeGroups.map(function (group) {
          const groupId = slugify(group.key);
          return '<li class="theme-doc-sidebar-item-category theme-doc-sidebar-item-category-level-2 menu__list-item menu__list-item--collapsed">' +
            '<div class="menu__list-item-collapsible">' +
            '<a class="menu__link menu__link--sublist" href="#components-' + escapeHtml(groupId) + '">' + escapeHtml(group.label) + '</a>' +
            '<button type="button" class="menu__caret" aria-label="Toggle ' + escapeHtml(group.label) + '" aria-expanded="false"></button>' +
            '</div>' +
            '<ul class="menu__list">' +
            group.items.map(function (item) {
              const itemAnchorId = getComponentAnchorId(item, group.itemKind);
              return '<li class="theme-doc-sidebar-item-link theme-doc-sidebar-item-link-level-3 menu__list-item">' +
                '<a class="menu__link" href="#' + escapeHtml(itemAnchorId) + '">' + escapeHtml(item.name || item.id) + '</a>' +
                '</li>';
            }).join('') +
            '</ul>' +
            '</li>';
        }).join('');
      }

      refreshNavigationCollections();
      bindNavigationInteractions();
    }

    function loadRenderModel() {
      if (!renderModelUrl) {
        return Promise.resolve(null);
      }

      const resolvedUrl = new URL(renderModelUrl, window.location.href).toString();
      return window.fetch(resolvedUrl)
        .then(function (response) {
          if (!response.ok) {
            throw new Error('Failed to load render model');
          }
          return response.json();
        })
        .then(function (renderModel) {
          currentRenderModel = renderModel;
          if (renderModel && Array.isArray(renderModel.servers) && renderModel.servers.length) {
            knownServerBases = renderModel.servers
              .map(function (server) { return server.defaultResolvedUrl; })
              .filter(Boolean);
          }
          hydrateOverview(renderModel);
          hydrateServers(renderModel);
          hydrateAuthentication(renderModel);
          hydrateOperations(renderModel);
          hydrateWebhooks(renderModel);
          hydrateComponents(renderModel);
          return renderModel;
        })
        .catch(function () {
          return null;
        });
    }

    function closeSidebar() {
      body.classList.remove('nav-open');
      sidebar.classList.remove('open');
      overlay.classList.remove('visible');
      menuToggle.setAttribute('aria-expanded', 'false');
    }

    function openSidebar() {
      body.classList.add('nav-open');
      sidebar.classList.add('open');
      overlay.classList.add('visible');
      menuToggle.setAttribute('aria-expanded', 'true');
    }

    function syncScrollToTopVisibility() {
      if (!scrollToTopButton) {
        return;
      }
      scrollToTopButton.hidden = window.scrollY < 240;
    }

    function expandParentCategories(link) {
      let parentItem = link.closest('.menu__list-item');
      while (parentItem) {
        parentItem.classList.remove('menu__list-item--collapsed');
        parentItem = parentItem.parentElement ? parentItem.parentElement.closest('.menu__list-item') : null;
      }
    }

    function setActiveLinkByHash(hash, options) {
      const opts = options || {};
      const normalizedHash = normalizeHash(hash);
      if (!normalizedHash || !linkByHash[normalizedHash]) {
        return;
      }
      if (activeHash === normalizedHash && !opts.force) {
        return;
      }

      activeHash = normalizedHash;
      const sectionHash = getSectionHash(normalizedHash);
      navLinks.forEach(function (item) {
        const itemHash = item.getAttribute('href');
        const isActive = itemHash === normalizedHash || (sectionHash && itemHash === sectionHash);
        item.classList.toggle('menu__link--active', isActive);
        if (isActive) {
          item.setAttribute('aria-current', itemHash === normalizedHash ? 'location' : 'true');
        } else {
          item.removeAttribute('aria-current');
        }
      });
      expandParentCategories(linkByHash[normalizedHash]);
      if (!opts.skipSidebarScroll) {
        linkByHash[normalizedHash].scrollIntoView({block: 'nearest'});
      }
    }

    function isHeadingVisible(heading) {
      if (!heading || !heading.getClientRects || !heading.getClientRects().length) {
        return false;
      }

      let current = heading;
      while (current && current !== document.body) {
        if (current.hidden) {
          return false;
        }
        current = current.parentElement;
      }

      return true;
    }

    function getActiveHashFromScroll() {
      const visibleHeadings = headings.filter(isHeadingVisible);
      if (!visibleHeadings.length) {
        return null;
      }

      const threshold = 120;
      let candidate = '#' + visibleHeadings[0].id;

      visibleHeadings.forEach(function (heading) {
        const top = heading.getBoundingClientRect().top;
        if (top - threshold <= 0) {
          candidate = '#' + heading.id;
        }
      });

      return candidate;
    }

    function setCodeTab(group, tabId) {
      const tabs = Array.from(group.querySelectorAll('[data-code-tab]'));
      const panes = Array.from(group.querySelectorAll('[data-code-pane]'));

      tabs.forEach(function (tab) {
        const isActive = tab.getAttribute('data-code-tab') === tabId;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      panes.forEach(function (pane) {
        const isActive = pane.getAttribute('data-code-pane') === tabId;
        pane.classList.toggle('is-active', isActive);
        pane.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });
    }

    function getPreferredLanguage() {
      try {
        const value = window.localStorage.getItem(languageStorageKey);
        return value || defaultLanguage;
      } catch (error) {
        return defaultLanguage;
      }
    }

    function setPreferredLanguage(value) {
      try {
        window.localStorage.setItem(languageStorageKey, value);
      } catch (error) {
        // ignore storage failures
      }
    }

    function getAvailableTabs(group) {
      return Array.from(group.querySelectorAll('[data-code-tab]')).map(function (tab) {
        return tab.getAttribute('data-code-tab');
      });
    }

    function resolveGroupLanguage(group, preferredLanguage) {
      const availableTabs = getAvailableTabs(group);
      if (!availableTabs.length) {
        return null;
      }
      if (availableTabs.indexOf(preferredLanguage) !== -1) {
        return preferredLanguage;
      }
      if (availableTabs.indexOf(defaultLanguage) !== -1) {
        return defaultLanguage;
      }
      return availableTabs[0];
    }

    function applyLanguageToAllGroups(language) {
      if (!language) {
        return;
      }
      document.documentElement.setAttribute('data-code-language', language);
      languageTabGroups.forEach(function (group) {
        const resolved = resolveGroupLanguage(group, language);
        if (resolved) {
          setCodeTab(group, resolved);
        }
      });
    }

    function syncPreferredLanguage(language) {
      if (!language) {
        return;
      }
      setPreferredLanguage(language);
      applyLanguageToAllGroups(language);
    }

    function refreshCodeExampleCollections() {
      tabGroups = Array.from(document.querySelectorAll('[data-code-tabs]'));
      languageTabGroups = tabGroups.filter(function (group) {
        return group.getAttribute('data-code-sync') === 'language';
      });
      copyButtons = Array.from(document.querySelectorAll('[data-copy-example]'));
    }

    function bindCodeExampleInteractions() {
      tabGroups.forEach(function (group) {
        const isLanguageGroup = group.getAttribute('data-code-sync') === 'language';
        const firstTab = group.querySelector('[data-code-tab]');
        if (!group.__kairosInitialized && !isLanguageGroup && firstTab) {
          setCodeTab(group, firstTab.getAttribute('data-code-tab'));
        }
        group.__kairosInitialized = true;

        group.querySelectorAll('[data-code-tab]').forEach(function (tab) {
          if (tab.__kairosBound) {
            return;
          }
          tab.__kairosBound = true;
          tab.addEventListener('click', function () {
            const selectedTab = tab.getAttribute('data-code-tab');
            if (isLanguageGroup) {
              syncPreferredLanguage(selectedTab);
              return;
            }
            setCodeTab(group, selectedTab);
          });
        });
      });

      applyLanguageToAllGroups(getPreferredLanguage());

      copyButtons.forEach(function (button) {
        if (button.__kairosBound) {
          return;
        }
        button.__kairosBound = true;
        button.addEventListener('click', function () {
          const text = getPanelCopyText(button);
          if (!text) {
            return;
          }

          writeClipboardText(text).then(function () {
            button.classList.add('is-copied');
            button.textContent = 'Copied';
            window.setTimeout(function () {
              button.classList.remove('is-copied');
              button.textContent = 'Copy';
            }, 1200);
          }).catch(function () {
            button.textContent = 'Failed';
            window.setTimeout(function () {
              button.textContent = 'Copy';
            }, 1200);
          });
        });
      });
    }

    function bindVariantInteractions() {
      variantGroups.forEach(function (group) {
        group.querySelectorAll('[data-variant-button]').forEach(function (button) {
          if (button.__kairosBound) {
            return;
          }
          button.__kairosBound = true;
          button.addEventListener('click', function () {
            const variantId = button.getAttribute('data-variant-button');
            const parent = group.parentElement;
            if (!parent) {
              return;
            }
            Array.from(group.querySelectorAll('[data-variant-button]')).forEach(function (item) {
              const isActive = item === button;
              item.classList.toggle('is-active', isActive);
              item.setAttribute('aria-selected', isActive ? 'true' : 'false');
            });
            Array.from(parent.querySelectorAll(':scope > [data-variant-pane]')).forEach(function (pane) {
              const isActive = pane.getAttribute('data-variant-pane') === variantId;
              pane.classList.toggle('is-active', isActive);
              pane.setAttribute('aria-hidden', isActive ? 'false' : 'true');
            });
            applyLanguageToAllGroups(getPreferredLanguage());
            const tryItPanel = parent.querySelector('[data-try-it-panel]');
            if (tryItPanel) {
              updateTryItPreview(tryItPanel);
            }
          });
        });
      });
    }

    function getPanelCopyText(button) {
      const panel = button.closest('.example-panel');
      if (!panel) {
        return '';
      }

      const activePanes = Array.from(panel.querySelectorAll('.code-pane.is-active'));
      const visibleActivePane = activePanes.find(function (pane) {
        return !pane.closest('[data-variant-pane]') || pane.closest('[data-variant-pane]').classList.contains('is-active');
      });
      if (visibleActivePane) {
        const activeCode = visibleActivePane.querySelector('code');
        return activeCode ? (activeCode.textContent || '') : '';
      }

      const visibleVariantPane = panel.querySelector('[data-variant-pane].is-active');
      if (visibleVariantPane) {
        const visibleVariantCode = visibleVariantPane.querySelector('pre code');
        if (visibleVariantCode) {
          return visibleVariantCode.textContent || '';
        }
      }

      const plainCode = panel.querySelector(':scope > pre code, pre code');
      if (plainCode) {
        return plainCode.textContent || '';
      }

      return '';
    }

    function writeClipboardText(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text);
      }

      return new Promise(function (resolve, reject) {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'absolute';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        try {
          const ok = document.execCommand('copy');
          document.body.removeChild(textarea);
          if (ok) {
            resolve();
          } else {
            reject(new Error('Copy command failed'));
          }
        } catch (error) {
          document.body.removeChild(textarea);
          reject(error);
        }
      });
    }

    function findOperationById(operationId) {
      if (!currentRenderModel || !Array.isArray(currentRenderModel.operations)) {
        return null;
      }

      return currentRenderModel.operations.find(function (operation) {
        return operation.id === operationId;
      }) || null;
    }

    function getActiveRequestVariant(operationCard, operation) {
      const requestVariants = operation && operation.examples && operation.examples.request && operation.examples.request.length
        ? operation.examples.request
        : [{ id: 'default', summary: null, value: undefined }];

      const activePane = operationCard.querySelector('[data-variant-pane].is-active');
      if (!activePane) {
        return requestVariants[0];
      }

      const activeVariantId = activePane.getAttribute('data-variant-pane');
      return requestVariants.find(function (variant, index) {
        return (variant.id || String(index)) === activeVariantId;
      }) || requestVariants[0];
    }

    function setTryItState(panel, statusText, options) {
      const opts = options || {};
      const status = panel.querySelector('[data-try-it-status]');
      const response = panel.querySelector('[data-try-it-response]');
      const responseStatus = panel.querySelector('[data-try-it-response-status]');
      const responseTiming = panel.querySelector('[data-try-it-response-timing]');
      const responseHeaders = panel.querySelector('[data-try-it-response-headers]');
      const responseBody = panel.querySelector('[data-try-it-response-body]');

      if (status) {
        status.textContent = statusText;
        status.dataset.state = opts.state || 'idle';
      }

      if (!response || !responseStatus || !responseTiming || !responseHeaders || !responseBody) {
        return;
      }

      if (opts.responseMeta || opts.responseBodyText || opts.responseHeadersText) {
        response.hidden = false;
        responseStatus.textContent = opts.responseMeta && opts.responseMeta.status ? opts.responseMeta.status : '-';
        responseTiming.textContent = opts.responseMeta && opts.responseMeta.timing ? opts.responseMeta.timing : '-';
        responseHeaders.textContent = opts.responseHeadersText || '(no response headers)';
        responseBody.textContent = opts.responseBodyText || '(empty response body)';
      } else {
        response.hidden = true;
        responseStatus.textContent = 'Ready';
        responseTiming.textContent = '-';
        responseHeaders.textContent = '';
        responseBody.textContent = '';
      }
    }

    function formatResponseHeaders(headers) {
      const entries = [];
      headers.forEach(function (value, key) {
        entries.push(key + ': ' + value);
      });
      return entries.length ? entries.join('\n') : '(no response headers)';
    }

    function formatResponseBody(text, contentType) {
      if (!text) {
        return '(empty response body)';
      }

      if (contentType && contentType.indexOf('application/json') !== -1) {
        try {
          return JSON.stringify(JSON.parse(text), null, 2);
        } catch (error) {
          return text;
        }
      }

      return text;
    }

    function classifyTryItFailure(error, requestData) {
      const requestUrl = requestData && requestData.url ? new URL(requestData.url, window.location.href) : null;
      const pageOrigin = window.location.origin;
      const isCrossOrigin = requestUrl ? requestUrl.origin !== pageOrigin : true;
      const isOffline = typeof navigator !== 'undefined' && navigator.onLine === false;
      const message = error && error.message ? error.message : '';

      if (isOffline) {
        return {
          summary: 'Request failed because the browser appears to be offline.',
          detail: 'Check your network connection and try again.',
          status: 'Offline'
        };
      }

      if (error && error.name === 'TypeError' && isCrossOrigin) {
        return {
          summary: 'Request failed before a response was received. This usually means the target API blocked the browser request.',
          detail: 'The most common cause is missing or restrictive CORS headers on the target server.',
          status: 'CORS / Network blocked'
        };
      }

      if (error && error.name === 'TypeError') {
        return {
          summary: 'Request failed before a response was received.',
          detail: 'The browser could not complete the request. This can be caused by DNS, TLS, ad blockers, local network rules, or browser security policies.',
          status: 'Network failure'
        };
      }

      return {
        summary: 'Request failed before a response was received.',
        detail: message || 'Unexpected browser request failure.',
        status: 'Request failure'
      };
    }

    function stripUnsafeControlChars(value) {
      return String(value == null ? '' : value).replace(/[\u0000-\u0008\u000B\u000C\u000E-\u001F\u007F]/g, '');
    }

    function sanitizePathValue(value) {
      return stripUnsafeControlChars(value).replace(/[\r\n]/g, '');
    }

    function sanitizeQueryValue(value) {
      return stripUnsafeControlChars(value).replace(/[\r\n]/g, '');
    }

    function sanitizeHeaderName(name) {
      const normalized = stripUnsafeControlChars(name).trim();
      if (!/^[!#$%&'*+\-.^_`|~0-9A-Za-z]+$/.test(normalized)) {
        throw new Error('Invalid header name: ' + name);
      }
      return normalized;
    }

    function sanitizeHeaderValue(value) {
      return stripUnsafeControlChars(value).replace(/[\r\n]+/g, ' ').trim();
    }

    function sanitizeCookiePair(name, value) {
      const safeName = stripUnsafeControlChars(name).replace(/[=\s;\r\n]/g, '');
      const safeValue = stripUnsafeControlChars(value).replace(/[;\r\n]/g, '');
      if (!safeName) {
        throw new Error('Invalid cookie name.');
      }
      return safeName + '=' + safeValue;
    }

    function buildTryItFetchOptions(requestData) {
      const headers = requestData.headers.reduce(function (acc, header) {
        const safeHeaderName = sanitizeHeaderName(header.name);
        const safeHeaderValue = sanitizeHeaderValue(header.value);
        if (safeHeaderName.toLowerCase() === 'cookie') {
          return acc;
        }
        if (requestData.mediaType && requestData.mediaType.indexOf('multipart/form-data') === 0 && safeHeaderName.toLowerCase() === 'content-type') {
          return acc;
        }
        acc[safeHeaderName] = safeHeaderValue;
        return acc;
      }, {});

      const options = {
        method: requestData.method,
        headers: headers,
        mode: 'cors'
      };

      if (requestData.body !== null) {
        const contentType = requestData.mediaType || headers['Content-Type'] || headers['content-type'] || '';
        if (requestData.body instanceof window.FormData) {
          options.body = requestData.body;
        } else if (contentType.indexOf('multipart/form-data') !== -1) {
          throw new Error('Multipart request data is invalid.');
        } else {
          options.body = JSON.stringify(requestData.body);
        }
      }

      return options;
    }

    function buildTryItRequestData(panel, operationCard, operation) {
      const requestVariant = getActiveRequestVariant(operationCard, operation);
      const requestData = buildRequestExampleData(currentRenderModel, operation, requestVariant);
      let url = new URL(requestData.url);
      let customPath = operation.path || url.pathname;

      Array.from(panel.querySelectorAll('[data-try-it-param]')).forEach(function (input) {
        const token = input.getAttribute('data-try-it-param') || '';
        const parts = token.split(':');
        const location = parts[0];
        const name = parts.slice(1).join(':');
        const value = input.type === 'file' ? (input.files && input.files[0] ? input.files[0] : null) : input.value;

        if (location === 'path') {
          customPath = customPath.replace(new RegExp('\\{' + name + '\\}', 'g'), encodeURIComponent(sanitizePathValue(value)));
          return;
        }

        if (location === 'query') {
          if (value === '') {
            url.searchParams.delete(name);
          } else {
            url.searchParams.set(name, sanitizeQueryValue(value));
          }
          return;
        }

        if (location === 'header') {
          const safeHeaderName = sanitizeHeaderName(name);
          const safeHeaderValue = sanitizeHeaderValue(value);
          const existingHeader = requestData.headers.find(function (header) {
            return header.name.toLowerCase() === safeHeaderName.toLowerCase();
          });
          if (existingHeader) {
            existingHeader.name = safeHeaderName;
            existingHeader.value = safeHeaderValue;
          } else if (value !== '') {
            requestData.headers.push({ name: safeHeaderName, value: safeHeaderValue });
          }
          return;
        }

        if (location === 'cookie') {
          const cookieValue = sanitizeCookiePair(name, value);
          const existingCookie = requestData.headers.find(function (header) {
            return header.name.toLowerCase() === 'cookie' && String(header.value).indexOf(name + '=') === 0;
          });
          if (existingCookie) {
            existingCookie.value = cookieValue;
          } else if (value !== '') {
            requestData.headers.push({ name: 'Cookie', value: cookieValue });
          }
        }
      });

      url = new URL(url.origin + customPath + url.search);

      const multipartFields = Array.from(panel.querySelectorAll('[data-try-it-param^="multipart:"]'));
      if (multipartFields.length) {
        const formData = new window.FormData();
        multipartFields.forEach(function (input) {
          const token = input.getAttribute('data-try-it-param') || '';
          const fieldName = token.slice('multipart:'.length);
          const required = input.getAttribute('data-try-it-required') === 'true';

          if (input.type === 'file') {
            const file = input.files && input.files[0] ? input.files[0] : null;
            if (!file) {
              if (required) {
                throw new Error('Please choose a file for ' + fieldName + '.');
              }
              return;
            }
            formData.append(fieldName, file);
            return;
          }

          const rawValue = input.value.trim();
          if (!rawValue) {
            if (required) {
              throw new Error('Please provide a value for ' + fieldName + '.');
            }
            return;
          }

          if (input.tagName === 'TEXTAREA') {
            try {
              JSON.parse(stripUnsafeControlChars(rawValue));
            } catch (error) {
              throw new Error(fieldName + ' must be valid JSON.');
            }
          }

          formData.append(fieldName, stripUnsafeControlChars(rawValue));
        });
        requestData.body = formData;
      }

      const bodyInput = panel.querySelector('[data-try-it-body]');
      if (bodyInput) {
        const rawBody = stripUnsafeControlChars(bodyInput.value).trim();
        if (!rawBody) {
          requestData.body = null;
        } else {
          try {
            requestData.body = JSON.parse(rawBody);
          } catch (error) {
            throw new Error('Request body must be valid JSON.');
          }
        }
      }

      requestData.url = url.toString();
      return requestData;
    }

    function formatTryItPreview(requestData) {
      const lines = [requestData.method + ' ' + requestData.url];
      if (requestData.headers && requestData.headers.length) {
        lines.push('', 'Headers:');
        requestData.headers.forEach(function (header) {
          lines.push(header.name + ': ' + String(header.value));
        });
      }

      if (requestData.body instanceof window.FormData) {
        lines.push('', 'Body:');
        requestData.body.forEach(function (value, key) {
          if (value instanceof window.File) {
            lines.push(key + ': [File ' + value.name + ']');
          } else {
            lines.push(key + ': ' + String(value));
          }
        });
      } else if (requestData.body !== null) {
        lines.push('', 'Body:');
        lines.push(JSON.stringify(requestData.body, null, 2));
      }

      return lines.join('\n');
    }

    function updateTryItPreview(panel) {
      const preview = panel.querySelector('[data-try-it-preview] code');
      const operationId = panel.getAttribute('data-operation-id');
      const operationCard = panel.closest('.operation-card');
      const operation = findOperationById(operationId);

      if (!preview || !operation || !operationCard) {
        return;
      }

      try {
        const requestData = buildTryItRequestData(panel, operationCard, operation);
        preview.textContent = formatTryItPreview(requestData);
      } catch (error) {
        preview.textContent = error && error.message ? error.message : 'Request preview unavailable.';
      }
    }

    function updateAllTryItPreviews() {
      Array.from(document.querySelectorAll('[data-try-it-panel]')).forEach(function (panel) {
        updateTryItPreview(panel);
      });
    }

    function resetTryItPanel(panel) {
      const operationId = panel.getAttribute('data-operation-id');
      const operation = findOperationById(operationId);
      if (!operation) {
        return;
      }

      Array.from(panel.querySelectorAll('[data-try-it-param]')).forEach(function (input) {
        const token = input.getAttribute('data-try-it-param') || '';
        if (token.indexOf('multipart:') === 0) {
          const fieldName = token.slice('multipart:'.length);
          const requestBody = operation.requestBody && operation.requestBody.content && operation.requestBody.content.length
            ? operation.requestBody.content[0]
            : null;
          const requestBodyExample = getRequestBodyExample(operation.requestBody);
          const exampleValue = requestBodyExample && requestBodyExample.value && typeof requestBodyExample.value === 'object'
            ? requestBodyExample.value[fieldName]
            : undefined;
          const propertySchema = requestBody && requestBody.schema && requestBody.schema.properties
            ? requestBody.schema.properties[fieldName]
            : null;

          if (input.type === 'file') {
            input.value = '';
          } else if (input.tagName === 'TEXTAREA') {
            input.value = JSON.stringify(exampleValue !== undefined ? exampleValue : getSchemaDerivedExample(propertySchema), null, 2);
          } else {
            input.value = String(exampleValue !== undefined ? exampleValue : getScalarExample(propertySchema, fieldName) || '');
          }
          return;
        }

        const parts = token.split(':');
        const location = parts[0];
        const name = parts.slice(1).join(':');
        const parameterGroup = operation.parameters && operation.parameters[location] ? operation.parameters[location] : [];
        const parameter = parameterGroup.find(function (item) {
          return item.name === name;
        });

        if (input.type === 'file') {
          input.value = '';
        } else {
          input.value = parameter ? String(getParameterExample(parameter) || '') : '';
        }
      });

      const bodyInput = panel.querySelector('[data-try-it-body]');
      if (bodyInput) {
        const requestBodyExample = getRequestBodyExample(operation.requestBody);
        bodyInput.value = requestBodyExample ? JSON.stringify(requestBodyExample.value, null, 2) : '';
      }

      updateTryItPreview(panel);
      setTryItState(panel, 'Ready to send.', { state: 'idle' });
    }

    function bindTryItInteractions() {
      updateAllTryItPreviews();

      Array.from(document.querySelectorAll('[data-try-it-panel] [data-try-it-param], [data-try-it-panel] [data-try-it-body]')).forEach(function (input) {
        if (input.__kairosPreviewBound) {
          return;
        }
        input.__kairosPreviewBound = true;
        input.addEventListener('input', function () {
          const panel = input.closest('[data-try-it-panel]');
          if (panel) {
            updateTryItPreview(panel);
          }
        });
        input.addEventListener('change', function () {
          const panel = input.closest('[data-try-it-panel]');
          if (panel) {
            updateTryItPreview(panel);
          }
        });
      });

      Array.from(document.querySelectorAll('[data-try-it-send]')).forEach(function (button) {
        if (button.__kairosBound) {
          return;
        }

        button.__kairosBound = true;
        button.addEventListener('click', function () {
          const panel = button.closest('[data-try-it-panel]');
          if (!panel) {
            return;
          }

          const operationId = panel.getAttribute('data-operation-id');
          const operationCard = button.closest('.operation-card');
          const operation = findOperationById(operationId);
          if (!operation || !operationCard) {
            return;
          }

          setTryItState(panel, 'Sending request...', { state: 'pending' });
          button.disabled = true;

          let requestData;
          try {
            requestData = buildTryItRequestData(panel, operationCard, operation);
          } catch (error) {
            setTryItState(panel, error.message || 'Request cannot be prepared.', { state: 'error' });
            button.disabled = false;
            return;
          }

          let requestOptions;
          try {
            requestOptions = buildTryItFetchOptions(requestData);
          } catch (error) {
            setTryItState(panel, error.message || 'Request cannot be sent yet.', { state: 'error' });
            button.disabled = false;
            return;
          }

          const startedAt = window.performance && typeof window.performance.now === 'function'
            ? window.performance.now()
            : Date.now();

          window.fetch(requestData.url, requestOptions)
            .then(function (response) {
              return response.text().then(function (text) {
                const finishedAt = window.performance && typeof window.performance.now === 'function'
                  ? window.performance.now()
                  : Date.now();
                const duration = Math.max(0, Math.round(finishedAt - startedAt));
                const contentType = response.headers.get('content-type') || '';
                setTryItState(
                  panel,
                  response.status + ' ' + response.statusText + ' in ' + duration + ' ms',
                  {
                    state: response.ok ? 'success' : 'error',
                    responseMeta: {
                      status: response.status + ' ' + response.statusText,
                      timing: duration + ' ms'
                    },
                    responseHeadersText: formatResponseHeaders(response.headers),
                    responseBodyText: formatResponseBody(text, contentType)
                  }
                );
              });
            })
            .catch(function (error) {
              const failure = classifyTryItFailure(error, requestData);
              setTryItState(
                panel,
                failure.summary,
                {
                  state: 'error',
                  responseMeta: {
                    status: failure.status,
                    timing: '-'
                  },
                  responseHeadersText: '(no response headers)',
                  responseBodyText: failure.detail
                }
              );
            })
            .finally(function () {
              button.disabled = false;
            });
        });
      });

      Array.from(document.querySelectorAll('[data-try-it-reset]')).forEach(function (button) {
        if (button.__kairosBound) {
          return;
        }

        button.__kairosBound = true;
        button.addEventListener('click', function () {
          const panel = button.closest('[data-try-it-panel]');
          if (!panel) {
            return;
          }
          resetTryItPanel(panel);
        });
      });
    }

    function normalizeServerPath(pathname) {
      if (!pathname || pathname === '/') {
        return '';
      }
      return pathname.replace(/\/+$/, '');
    }

    function resolveServerUrl(template, values) {
      return template.replace(/\{([^}]+)\}/g, function (_, name) {
        return Object.prototype.hasOwnProperty.call(values, name) ? values[name] : '';
      });
    }

    function getServerCard(url) {
      return serverCards.find(function (card) {
        return card.getAttribute('data-server-option') === url;
      }) || null;
    }

    function getServerVariableValues(card) {
      return Array.from(card.querySelectorAll('[data-server-variable]')).reduce(function (acc, input) {
        acc[input.getAttribute('data-server-variable-name')] = input.value;
        return acc;
      }, {});
    }

    function joinServerUrl(baseUrl, suffix) {
      const parsed = new URL(baseUrl);
      const basePath = normalizeServerPath(parsed.pathname);
      const parts = (suffix || '/').match(/^([^?#]*)(.*)$/) || ['', '/', ''];
      let suffixPath = parts[1] || '/';
      const trailing = parts[2] || '';

      if (basePath && suffixPath === basePath) {
        suffixPath = '/';
      } else if (basePath && suffixPath.indexOf(basePath + '/') === 0) {
        suffixPath = suffixPath.slice(basePath.length);
      }

      if (!suffixPath) {
        suffixPath = '/';
      }
      if (suffixPath.charAt(0) !== '/') {
        suffixPath = '/' + suffixPath;
      }

      return parsed.origin + (basePath + suffixPath).replace(/\/{2,}/g, '/') + trailing;
    }

    function replaceServerAwareUrls(text, resolvedUrl) {
      return text.replace(/https?:\/\/[^\s'"<>()]+/g, function (url) {
        const matchedBase = knownServerBases.find(function (base) {
          return url.indexOf(base) === 0;
        });

        if (!matchedBase) {
          return url;
        }

        return joinServerUrl(resolvedUrl, url.slice(matchedBase.length) || '/');
      });
    }

    function updateServerAwareExamples(resolvedUrl) {
      Array.from(document.querySelectorAll('[data-example-base-url] pre code, main pre code')).forEach(function (block) {
        if (!block.__originalText) {
          block.__originalText = block.textContent || '';
        }
        block.textContent = replaceServerAwareUrls(block.__originalText, resolvedUrl);
      });
    }

    function readServerState() {
      if (!serverSelect || !serverCards.length) {
        return null;
      }

      const selectedServerId = serverSelect.value || serverCards[0].getAttribute('data-server-option');
      const activeCard = getServerCard(selectedServerId) || serverCards[0];
      const values = getServerVariableValues(activeCard);

      return {
        selectedServerId: activeCard.getAttribute('data-server-option'),
        values: values,
        resolvedUrl: resolveServerUrl(activeCard.getAttribute('data-server-template'), values)
      };
    }

    function persistServerState(state) {
      try {
        window.localStorage.setItem(serverStorageKey, JSON.stringify({
          selectedServerId: state.selectedServerId,
          values: state.values
        }));
      } catch (error) {
        // ignore storage failures
      }
    }

    function applyServerState(options) {
      const opts = options || {};
      const state = readServerState();

      if (!state) {
        return;
      }

      serverCards.forEach(function (card) {
        const isActive = card.getAttribute('data-server-option') === state.selectedServerId;
        const values = getServerVariableValues(card);
        const preview = card.querySelector('[data-server-resolved]');
        card.classList.toggle('is-active', isActive);

        if (preview) {
          preview.textContent = resolveServerUrl(card.getAttribute('data-server-template'), values);
        }
      });

      if (serverSummary) {
        serverSummary.textContent = state.resolvedUrl;
      }

      updateServerAwareExamples(state.resolvedUrl);
      updateAllTryItPreviews();

      if (!opts.skipPersistence) {
        persistServerState(state);
      }
    }

    function restoreServerState() {
      if (!serverSelect || !serverCards.length) {
        return;
      }

      serverCards.forEach(function (card) {
        Array.from(card.querySelectorAll('[data-server-variable]')).forEach(function (input) {
          const defaultValue = input.getAttribute('data-server-default-value');
          if (defaultValue !== null) {
            input.value = defaultValue;
          }
        });
      });

      let stored = null;

      try {
        stored = JSON.parse(window.localStorage.getItem(serverStorageKey) || 'null');
      } catch (error) {
        stored = null;
      }

      if (stored && getServerCard(stored.selectedServerId)) {
        serverSelect.value = stored.selectedServerId;
        Array.from(getServerCard(stored.selectedServerId).querySelectorAll('[data-server-variable]')).forEach(function (input) {
          const variableName = input.getAttribute('data-server-variable-name');
          if (Object.prototype.hasOwnProperty.call(stored.values || {}, variableName)) {
            input.value = stored.values[variableName];
          }
        });
      }

      applyServerState({skipPersistence: true});
    }

    function bindServerInteractions() {
      if (serverSelect && !serverSelect.__kairosBound) {
        serverSelect.__kairosBound = true;
        serverSelect.addEventListener('change', function () {
          applyServerState();
        });
      }

      serverCards.forEach(function (card) {
        Array.from(card.querySelectorAll('[data-server-variable]')).forEach(function (input) {
          if (input.__kairosBound) {
            return;
          }
          input.__kairosBound = true;
          input.addEventListener('change', function () {
            applyServerState();
          });
          input.addEventListener('input', function () {
            applyServerState();
          });
        });
      });
    }

    function renderMarkdownLinks() {
      Array.from(document.querySelectorAll('[data-render-md-links]')).forEach(function (element) {
        const source = element.innerHTML;
        if (!source) {
          return;
        }

        const codeBlocks = [];
        const withCodeBlocks = source.replace(/```([a-zA-Z0-9_-]+)?\n?([\s\S]*?)```/g, function (_, language, code) {
          const blockClass = language ? ' class="language-' + escapeHtml(language) + '"' : '';
          const html = '<pre><code' + blockClass + '>' + escapeHtml(code.trim()) + '</code></pre>';
          const token = '__CODE_BLOCK_' + codeBlocks.length + '__';
          codeBlocks.push(html);
          return token;
        });

        const withLinks = withCodeBlocks.replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, function (_, label, href) {
          const isExternal = /^https?:\/\//i.test(href);
          if (isExternal) {
            return '<a href="' + href + '" target="_blank" rel="noopener noreferrer">' + label + '</a>';
          }
          return '<a href="' + href + '">' + label + '</a>';
        });

        const withInlineCode = withLinks.replace(/`([^`\n]+)`/g, function (_, inlineCode) {
          return '<code>' + escapeHtml(inlineCode) + '</code>';
        });

        const rendered = withInlineCode.replace(/__CODE_BLOCK_(\d+)__/g, function (_, index) {
          const block = codeBlocks[Number(index)];
          return block || '';
        });

        element.innerHTML = rendered;
      });
    }

    function clearSensitiveRuntimeState() {
      authState = {};

      Array.from(document.querySelectorAll('[data-auth-input]')).forEach(function (input) {
        if (input.tagName === 'SELECT') {
          input.selectedIndex = 0;
          return;
        }
        input.value = '';
      });

      Array.from(document.querySelectorAll('[data-try-it-panel]')).forEach(function (panel) {
        Array.from(panel.querySelectorAll('[data-try-it-param], [data-try-it-body]')).forEach(function (input) {
          if (input.type === 'file') {
            input.value = '';
            return;
          }
          input.value = '';
        });
        updateTryItPreview(panel);
        setTryItState(panel, 'Ready to send.', { state: 'idle' });
      });
    }

    menuToggle.addEventListener('click', function () {
      const isOpen = sidebar.classList.contains('open');
      if (isOpen) {
        closeSidebar();
        return;
      }
      openSidebar();
    });

    overlay.addEventListener('click', closeSidebar);

    refreshNavigationCollections();
    bindNavigationInteractions();

    refreshCodeExampleCollections();
    refreshVariantCollections();
    bindCodeExampleInteractions();
    bindVariantInteractions();
    syncScrollToTopVisibility();

    renderMarkdownLinks();

    if (scrollToTopButton) {
      scrollToTopButton.addEventListener('click', function () {
        navigateToHash('#overview');
      });
    }

    window.addEventListener('pagehide', clearSensitiveRuntimeState);

    window.addEventListener('hashchange', function () {
      const nextHash = normalizeHash(window.location.hash);
      navigateToHash(nextHash, {
        skipDocumentHash: true,
        skipSidebarScroll: false
      });
    });

    window.addEventListener('scroll', function () {
      if (scrollTicking) {
        return;
      }
      scrollTicking = true;
      window.requestAnimationFrame(function () {
        syncScrollToTopVisibility();
        const hash = getActiveHashFromScroll();
        navigateToHash(hash, {
          skipScroll: true,
          skipSidebarScroll: true,
          replaceHistory: true
        });
        scrollTicking = false;
      });
    }, {passive: true});

    function syncNavigationStateAfterHydration() {
      const startupHash = normalizeHash(window.location.hash);
      if (startupHash && linkByHash[startupHash]) {
        navigateToHash(startupHash, {
          skipDocumentHash: true
        });
        return;
      }

      const initialScrollHash = getActiveHashFromScroll();
      if (initialScrollHash) {
        navigateToHash(initialScrollHash, {
          skipScroll: true,
          skipSidebarScroll: true,
          replaceHistory: true
        });
      } else if (navLinks.length) {
        const firstHash = navLinks[0].getAttribute('href');
        navigateToHash(firstHash, {
          skipScroll: true,
          skipSidebarScroll: true,
          replaceHistory: true
        });
      }
    }

    loadRenderModel().then(function () {
      refreshNavigationCollections();
      bindNavigationInteractions();
      syncTryItShellsForViewport();
      syncNavigationStateAfterHydration();
    });

    window.addEventListener('resize', function () {
      syncTryItShellsForViewport();
    }, {passive: true});
  }());
</script>
