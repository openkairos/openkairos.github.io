    function renderComponentCard(item, kind) {
      const title = item.name || item.id;
      const anchorId = getComponentAnchorId(item, kind);
      const primaryValue = kind === 'schema' ? item.schema : item.value;
      const examples = Array.isArray(item.examples) ? item.examples : [];

      return '<article class="card operation-card component-card">' +
        '<h4 class="anchor" id="' + escapeHtml(anchorId) + '">' + escapeHtml(title) +
        '<a href="#' + escapeHtml(anchorId) + '" class="hash-link" aria-label="Direct link to ' + escapeHtml(title) + '" title="Direct link to ' + escapeHtml(title) + '" translate="no">\u200b</a>' +
        '</h4>' +
        '<p class="component-card__meta"><strong>Reference:</strong> <code>' + escapeHtml(item.sourceRef || '') + '</code></p>' +
        (item.description ? '<p class="component-card__description">' + escapeHtml(item.description) + '</p>' : '') +
        (primaryValue ? renderJsonExplorer(kind === 'schema' ? 'Schema' : 'Value', primaryValue) : '') +
