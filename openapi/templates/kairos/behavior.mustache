      if (webhooksNavGroup && webhooksNavList) {
        webhooksNavGroup.hidden = false;
        webhooksNavList.innerHTML = orderedNames.map(function (name) {
          const hookId = slugify(name);
          return '<li class="theme-doc-sidebar-item-category theme-doc-sidebar-item-category-level-2 menu__list-item menu__list-item--collapsed">' +
            '<div class="menu__list-item-collapsible">' +
            '<a class="menu__link menu__link--sublist" href="#webhook-group-' + escapeHtml(hookId) + '">' + escapeHtml(name) + '</a>' +
            '<button type="button" class="menu__caret" aria-label="Toggle ' + escapeHtml(name) + ' webhook" aria-expanded="false"></button>' +
            '</div>' +
            '<ul class="menu__list">' +
            '<li class="theme-doc-sidebar-item-link theme-doc-sidebar-item-link-level-3 menu__list-item">' +
            '<a class="menu__link" href="#webhook-group-' + escapeHtml(hookId) + '">Overview</a>' +
            '</li>' +
            groupedByName[name].map(function (webhook) {
              const webhookAnchorId = getOperationAnchorId(webhook, 'webhook');
              return '<li class="theme-doc-sidebar-item-link theme-doc-sidebar-item-link-level-3 menu__list-item">' +
                '<a class="menu__link" href="#' + escapeHtml(webhookAnchorId) + '">' + escapeHtml(webhook.summary || webhook.id) + '</a>' +
                '</li>';
