    function renderLinks(links) {
      if (!links || !links.length) {
        return '';
      }

      return '<div class="operation-linked-list">' +
        links.map(function (link) {
          return '<div class="card operation-content-card">' +
            '<h4>Link <code>' + escapeHtml(link.id) + '</code></h4>' +
            (link.description ? '<p class="operation-card__text">' + escapeHtml(link.description) + '</p>' : '') +
            (link.operationId ? '<p class="operation-card__meta-line"><strong>Operation:</strong> <code>' + escapeHtml(link.operationId) + '</code></p>' : '') +
            (link.operationRef ? '<p class="operation-card__meta-line"><strong>Operation ref:</strong> <code>' + escapeHtml(link.operationRef) + '</code></p>' : '') +
            (link.parameters ? '<p class="operation-card__meta-line"><strong>Parameters:</strong></p><pre><code>' + escapeHtml(stringifyValue(link.parameters)) + '</code></pre>' : '') +
            (link.requestBody ? '<p class="operation-card__meta-line"><strong>Request body:</strong></p><pre><code>' + escapeHtml(stringifyValue(link.requestBody)) + '</code></pre>' : '') +
            (link.server ? '<p class="operation-card__meta-line"><strong>Server:</strong></p><pre><code>' + escapeHtml(stringifyValue(link.server)) + '</code></pre>' : '') +
            '</div>';
        }).join('') +
        '</div>';
    }

    function renderCallbacks(callbacks) {
      if (!callbacks || !callbacks.length) {
        return '';
      }

      return '<div class="operation-linked-list">' +
        callbacks.map(function (callback) {
          return '<div class="card operation-content-card">' +
            '<h4>Callback <code>' + escapeHtml(callback.id) + '</code></h4>' +
            callback.expressions.map(function (expression) {
              return '<div class="operation-callback-expression">' +
                '<p class="operation-card__meta-line"><strong>Expression:</strong> <code>' + escapeHtml(expression.expression) + '</code></p>' +
                expression.operations.map(function (operation) {
                  return '<div class="operation-callback-operation">' +
                    '<div class="endpoint"><span class="method ' + escapeHtml(operation.method) + '">' + escapeHtml(operation.method.toUpperCase()) + '</span><span>' + escapeHtml(operation.summary || 'Callback operation') + '</span></div>' +
                    (operation.description ? '<p class="operation-card__text">' + escapeHtml(operation.description) + '</p>' : '') +
                    renderRequestBody(operation.requestBody) +
                    renderResponses(operation.responses) +
                    '</div>';
                }).join('') +
                '</div>';
            }).join('') +
            '</div>';
        }).join('') +
        '</div>';
    }

    function getDefaultServerUrl(renderModel, operation) {
      const activeServerState = readServerState();
      if (activeServerState && activeServerState.resolvedUrl) {
        return activeServerState.resolvedUrl;
      }
      if (operation && operation.servers && operation.servers.length && operation.servers[0].defaultResolvedUrl) {
        return operation.servers[0].defaultResolvedUrl;
      }
      if (renderModel && renderModel.servers && renderModel.servers.length && renderModel.servers[0].defaultResolvedUrl) {
        return renderModel.servers[0].defaultResolvedUrl;
      }
      return 'https://api.kairos.example';
    }

    function getDefaultExampleValue(examples) {
      return examples && examples.length ? examples[0].value : null;
    }

    function getScalarExample(schema, fallbackName) {
      if (!schema) {
        return fallbackName || 'value';
      }
      if (schema.example !== undefined) {
        return schema.example;
      }
      if (schema.enum && schema.enum.length) {
        return schema.enum[0];
      }
      switch (schema.type) {
        case 'string':
          if (schema.format === 'date-time') {
            return '2026-03-18T11:30:00Z';
          }
          if (schema.format === 'email') {
            return 'user@example.com';
          }
          if (schema.format === 'uri') {
            return 'https://example.com';
          }
          return fallbackName || 'string';
        case 'integer':
        case 'number':
          return schema.minimum !== undefined ? schema.minimum : 1;
        case 'boolean':
          return true;
        case 'array':
          return [getScalarExample(schema.items, fallbackName)];
        case 'object':
          return getSchemaDerivedExample(schema);
        default:
          return fallbackName || 'value';
      }
    }

    function getSchemaDerivedExample(schema) {
      if (!schema) {
        return null;
      }
      if (schema.example !== undefined) {
        return schema.example;
      }
      if (schema.oneOf && schema.oneOf.length) {
        return getSchemaDerivedExample(schema.oneOf[0]);
      }
      if (schema.anyOf && schema.anyOf.length) {
        return getSchemaDerivedExample(schema.anyOf[0]);
      }
      if (schema.allOf && schema.allOf.length) {
        return getSchemaDerivedExample(schema.allOf[0]);
      }
      if (schema.type === 'object' || schema.properties) {
        return Object.entries(schema.properties || {}).reduce(function (acc, entry) {
          acc[entry[0]] = getScalarExample(entry[1], entry[0]);
          return acc;
        }, {});
      }
      return getScalarExample(schema);
    }

    function getParameterExample(parameter) {
      const explicit = getDefaultExampleValue(parameter.examples);
      if (explicit !== null && explicit !== undefined) {
        return explicit;
      }
      return getScalarExample(parameter.schema, parameter.name);
    }

    function getDefaultIncludedParameters(parameters) {
      return (parameters || []).filter(function (parameter) {
        return parameter.required || (parameter.examples && parameter.examples.length);
      });
    }

    function getRequestBodyExample(requestBody, explicitExample) {
      if (!requestBody || !requestBody.content || !requestBody.content.length) {
        return null;
      }
      const content = requestBody.content[0];
      const example = explicitExample !== undefined ? explicitExample : getDefaultExampleValue(content.examples);
      return {
        mediaType: content.mediaType,
        value: example !== null && example !== undefined ? example : getSchemaDerivedExample(content.schema)
      };
    }

    function getSelectedAuthScheme(renderModel) {
      const auth = renderModel && renderModel.auth ? renderModel.auth : null;
      const schemes = auth && Array.isArray(auth.schemes) ? auth.schemes : [];
      const selectedSchemeId = activeAuthSchemeId || (auth && auth.defaultSchemeId) || (schemes[0] && schemes[0].id);
      if (!selectedSchemeId) {
        return null;
      }
      return schemes.find(function (scheme) {
        return scheme.id === selectedSchemeId;
      }) || null;
    }

    function operationSupportsAuthScheme(operation, schemeId) {
      if (!schemeId) {
        return false;
      }

      const security = operation && Array.isArray(operation.security) ? operation.security : [];
      return security.some(function (requirement) {
        return Array.isArray(requirement.schemeIds) && requirement.schemeIds.indexOf(schemeId) !== -1;
      });
    }

    function encodeBasicCredentials(username, password) {
      const rawValue = String(username || '') + ':' + String(password || '');
      const sourceValue = rawValue === ':' ? 'YOUR_USERNAME:YOUR_PASSWORD' : rawValue;

      try {
        const bytes = new TextEncoder().encode(sourceValue);
        let binary = '';
        bytes.forEach(function (byte) {
          binary += String.fromCharCode(byte);
        });
        return window.btoa(binary);
      } catch (error) {
        try {
          return window.btoa(sourceValue);
        } catch (nestedError) {
          return 'YOUR_BASE64_CREDENTIALS';
        }
      }
    }

    function buildAuthEntriesForScheme(scheme) {
      if (!scheme) {
        return [];
      }

      const values = authState[scheme.id] || {};

      if (scheme.type === 'http' && scheme.scheme === 'bearer') {
        return [{ kind: 'header', name: 'Authorization', value: 'Bearer ' + (values.token || 'YOUR_TOKEN') }];
      }

      if (scheme.type === 'http' && scheme.scheme === 'basic') {
        return [{ kind: 'header', name: 'Authorization', value: 'Basic ' + encodeBasicCredentials(values.username, values.password) }];
      }

      if (scheme.type === 'apiKey') {
        const keyName = scheme.location && scheme.location.name ? scheme.location.name : 'api_key';
        const keyValue = values.value || 'YOUR_API_KEY';

        if (scheme.location && scheme.location.kind === 'query') {
          return [{ kind: 'query', name: keyName, value: keyValue }];
        }

        if (scheme.location && scheme.location.kind === 'cookie') {
          return [{ kind: 'header', name: 'Cookie', value: keyName + '=' + keyValue }];
        }

        return [{ kind: 'header', name: keyName, value: keyValue }];
      }

      if (scheme.type === 'oauth2') {
        return [{ kind: 'header', name: 'Authorization', value: 'Bearer ' + (values.token || 'YOUR_ACCESS_TOKEN') }];
      }

      if (scheme.type === 'openIdConnect') {
        return [{ kind: 'header', name: 'Authorization', value: 'Bearer ' + (values.token || 'YOUR_OPENID_TOKEN') }];
      }

      return [];
    }

    function getAuthPlaceholders(renderModel, operation) {
      const selectedScheme = getSelectedAuthScheme(renderModel);
      if (!selectedScheme || !operationSupportsAuthScheme(operation, selectedScheme.id)) {
        return [];
      }

      return buildAuthEntriesForScheme(selectedScheme);
    }

    function getExampleAuthState(renderModel, operation) {
      const selectedScheme = getSelectedAuthScheme(renderModel);
      const security = operation && Array.isArray(operation.security) ? operation.security : [];

      if (!selectedScheme) {
        return {
          selectedScheme: null,
          supported: !security.length,
          requiresAuth: security.length > 0
        };
      }

      return {
        selectedScheme: selectedScheme,
        supported: operationSupportsAuthScheme(operation, selectedScheme.id),
        requiresAuth: security.length > 0
      };
    }

    function renderExampleAuthNotice(renderModel, operation) {
      const authStateForExample = getExampleAuthState(renderModel, operation);

      if (!authStateForExample.selectedScheme || authStateForExample.supported) {
        return '';
      }

      if (!authStateForExample.requiresAuth) {
        return '<p class="example-panel__notice">The selected authentication method <code>' +
          escapeHtml(authStateForExample.selectedScheme.displayName || authStateForExample.selectedScheme.id) +
          '</code> is not applied because this operation does not require authentication.</p>';
      }

      return '<p class="example-panel__notice">The selected authentication method <code>' +
        escapeHtml(authStateForExample.selectedScheme.displayName || authStateForExample.selectedScheme.id) +
        '</code> is not supported by this operation, so the generated example omits auth.</p>';
    }

    function buildRequestExampleData(renderModel, operation, requestVariant) {
      const baseUrl = getDefaultServerUrl(renderModel, operation).replace(/\/$/, '');
      const pathParameters = getDefaultIncludedParameters(operation.parameters && operation.parameters.path);
      const queryParameters = getDefaultIncludedParameters(operation.parameters && operation.parameters.query);
      const headerParameters = getDefaultIncludedParameters(operation.parameters && operation.parameters.header);
      const cookieParameters = getDefaultIncludedParameters(operation.parameters && operation.parameters.cookie);
      const authPlaceholders = getAuthPlaceholders(renderModel, operation);
      const requestBody = getRequestBodyExample(operation.requestBody, requestVariant ? requestVariant.value : undefined);
      let path = operation.path || '/';

      pathParameters.forEach(function (parameter) {
        path = path.replace(new RegExp('\\{' + parameter.name + '\\}', 'g'), encodeURIComponent(String(getParameterExample(parameter))));
      });

      const queryPairs = queryParameters.map(function (parameter) {
        return [parameter.name, getParameterExample(parameter)];
      });
      authPlaceholders.filter(function (entry) { return entry.kind === 'query'; }).forEach(function (entry) {
        queryPairs.push([entry.name, entry.value]);
      });

      const queryString = queryPairs.length ? '?' + queryPairs.map(function (pair) {
        return encodeURIComponent(pair[0]) + '=' + encodeURIComponent(String(pair[1]));
      }).join('&') : '';

      const headers = headerParameters.map(function (parameter) {
        return { name: parameter.name, value: String(getParameterExample(parameter)) };
      });
      cookieParameters.forEach(function (parameter) {
        headers.push({ name: 'Cookie', value: parameter.name + '=' + String(getParameterExample(parameter)) });
      });
      authPlaceholders.filter(function (entry) { return entry.kind === 'header'; }).forEach(function (entry) {
        headers.push({ name: entry.name, value: entry.value });
      });
      if (requestBody && requestBody.mediaType) {
        headers.push({ name: 'Content-Type', value: requestBody.mediaType });
      }

      return {
        method: (operation.method || 'get').toUpperCase(),
        baseUrl: baseUrl,
        url: baseUrl + path + queryString,
        headers: headers,
        mediaType: requestBody && requestBody.mediaType ? requestBody.mediaType : null,
        body: requestBody && requestBody.value !== undefined ? requestBody.value : null
      };
    }

    function renderCurlExample(data) {
      const lines = ["curl --location '" + data.url + "'"];
      data.headers.forEach(function (header) {
        lines.push("--header '" + header.name + ': ' + String(header.value).replace(/'/g, "'\\''") + "'");
      });
      if (data.body !== null) {
        lines.push("--data-raw '" + JSON.stringify(data.body, null, 4).replace(/'/g, "'\\''") + "'");
      }
      return lines.join(' \\\n');
    }

    function renderJavaScriptExample(data) {
      const lines = [];
      lines.push('const myHeaders = new Headers();');
      data.headers.forEach(function (header) {
        lines.push('myHeaders.append(' + JSON.stringify(header.name) + ', ' + JSON.stringify(String(header.value)) + ');');
      });

      if (data.body !== null) {
        lines.push('');
        lines.push('const raw = JSON.stringify(' + JSON.stringify(data.body, null, 2) + ');');
      }

      lines.push('');
      lines.push('const requestOptions = {');
      lines.push('  method: ' + JSON.stringify(data.method) + ',');
      lines.push('  headers: myHeaders,');
      if (data.body !== null) {
        lines.push('  body: raw,');
      }
      lines.push('  redirect: "follow"');
      lines.push('};');
      lines.push('');
      lines.push('fetch(' + JSON.stringify(data.url) + ', requestOptions)');
      lines.push('  .then((response) => response.text())');
      lines.push('  .then((result) => console.log(result))');
      lines.push('  .catch((error) => console.error(error));');
      return lines.join('\n');
    }

    function renderPythonExample(data) {
      const lines = ['import requests'];
      const hasBody = data.body !== null;
      if (hasBody) {
        lines.push('import json');
      }
      lines.push('');
      lines.push('url = ' + JSON.stringify(data.url));

      if (hasBody) {
        lines.push('');
        lines.push('payload = json.dumps(' + JSON.stringify(data.body, null, 2) + ')');
      }

      if (data.body !== null) {
        lines.push('');
      }
      if (data.headers.length) {
        lines.push('headers = {');
        data.headers.forEach(function (header, index) {
          const suffix = index === data.headers.length - 1 ? '' : ',';
          lines.push("  " + JSON.stringify(header.name) + ': ' + JSON.stringify(String(header.value)) + suffix);
        });
        lines.push('}');
      } else {
        lines.push('headers = {}');
      }

      lines.push('');
      lines.push(
        'response = requests.request(' +
        JSON.stringify(data.method) +
        ', url, headers=headers' +
        (hasBody ? ', data=payload' : '') +
        ')'
      );
      lines.push('');
      lines.push('print(response.text)');
      return lines.join('\n');
    }

    function renderRubyExample(data) {
      const methodClass = data.method.charAt(0) + data.method.slice(1).toLowerCase();
      const lines = ['require "uri"', 'require "json"', 'require "net/http"', '', 'url = URI(' + JSON.stringify(data.url) + ')', '', 'http = Net::HTTP.new(url.host, url.port);', 'request = Net::HTTP::' + methodClass + '.new(url)'];
      data.headers.forEach(function (header) {
        lines.push('request[' + JSON.stringify(header.name) + '] = ' + JSON.stringify(String(header.value)));
      });
      if (data.body !== null) {
        lines.push('request.body = JSON.dump(' + JSON.stringify(data.body, null, 2) + ')');
      }
      lines.push('');
      lines.push('response = http.request(request)');
      lines.push('puts response.read_body');
      return lines.join('\n');
    }

    function renderPhpExample(data) {
      const lines = ['<?php', 'use GuzzleHttp\\\\Client;', 'use GuzzleHttp\\\\Psr7\\\\Request;', '', '$client = new Client();'];
      if (data.headers.length) {
        lines.push('$headers = [');
        data.headers.forEach(function (header, index) {
          const suffix = index === data.headers.length - 1 ? '' : ',';
          lines.push("  '" + header.name.replace(/'/g, "\\'") + "' => '" + String(header.value).replace(/'/g, "\\'") + "'" + suffix);
        });
        lines.push('];');
      } else {
        lines.push('$headers = [];');
      }
      if (data.body !== null) {
        lines.push('$body = \'' + JSON.stringify(data.body, null, 2).replace(/'/g, "\\'") + '\';');
      } else {
        lines.push('$body = \'\';');
      }
      lines.push('$request = new Request(' + JSON.stringify(data.method) + ', ' + JSON.stringify(data.url) + ', $headers, $body);');
      lines.push('$res = $client->sendAsync($request)->wait();');
      lines.push('echo $res->getBody();');
      return lines.join('\n');
    }

    function renderPhpValue(value, depth) {
      const indentUnit = '    ';
      const currentIndent = new Array(depth + 1).join(indentUnit);
      const nextIndent = new Array(depth + 2).join(indentUnit);

      if (value === null) {
        return 'null';
      }
      if (Array.isArray(value)) {
        if (!value.length) {
          return '[]';
        }
        return '[\n' + value.map(function (item) {
          return nextIndent + renderPhpValue(item, depth + 1) + ',';
        }).join('\n') + '\n' + currentIndent + ']';
      }
      if (typeof value === 'object') {
        const entries = Object.entries(value);
        if (!entries.length) {
          return '[]';
        }
        return '[\n' + entries.map(function (entry) {
          return nextIndent + '\'' + String(entry[0]).replace(/'/g, "\\'") + '\' => ' + renderPhpValue(entry[1], depth + 1) + ',';
        }).join('\n') + '\n' + currentIndent + ']';
      }
      if (typeof value === 'string') {
        return '\'' + value.replace(/\\/g, '\\\\').replace(/'/g, "\\'") + '\'';
      }
      if (typeof value === 'boolean') {
        return value ? 'true' : 'false';
      }
      return String(value);
    }

    function renderJavaExample(data) {
      const lines = [
        'OkHttpClient client = new OkHttpClient().newBuilder()',
        '  .build();'
      ];
      if (data.body !== null) {
        lines.push('MediaType mediaType = MediaType.parse("application/json");');
        lines.push('RequestBody body = RequestBody.create(mediaType, ' + JSON.stringify(JSON.stringify(data.body, null, 4)) + ');');
      }
      lines.push('Request request = new Request.Builder()');
      lines.push('  .url(' + JSON.stringify(data.url) + ')');
      lines.push('  .method(' + JSON.stringify(data.method) + ', ' + (data.body !== null ? 'body' : 'null') + ')');
      data.headers.forEach(function (header) {
        lines.push('  .addHeader(' + JSON.stringify(header.name) + ', ' + JSON.stringify(String(header.value)) + ')');
      });
      lines.push('  .build();');
      lines.push('Response response = client.newCall(request).execute();');
      return lines.join('\n');
    }

    function renderRequestExample(language, data) {
      switch (language) {
        case 'python':
          return renderPythonExample(data);
        case 'javascript':
          return renderJavaScriptExample(data);
        case 'ruby':
          return renderRubyExample(data);
        case 'php':
          return renderPhpExample(data);
        case 'java':
          return renderJavaExample(data);
        case 'curl':
        default:
          return renderCurlExample(data);
      }
    }

    function renderExamplePanel(renderModel, operation) {
      const requestVariants = operation.examples && operation.examples.request && operation.examples.request.length
        ? operation.examples.request
        : [{ id: 'default', summary: null, value: undefined }];

      return '<section class="example-panel">' +
        '<div class="example-panel__header">' +
          '<h3>Request Example</h3>' +
          '<button type="button" class="copy-example-btn" data-copy-example>Copy</button>' +
        '</div>' +
        renderExampleAuthNotice(renderModel, operation) +
        renderVariantSelector(requestVariants, { groupId: 'request-' + escapeHtml(operation.id) }) +
        requestVariants.map(function (variant, variantIndex) {
          const requestData = buildRequestExampleData(renderModel, operation, variant);
          return '<div class="variant-pane' + (variantIndex === 0 ? ' is-active' : '') + '" data-variant-pane="' + escapeHtml(variant.id || String(variantIndex)) + '">' +
            '<section class="example-panel__language-group" data-code-tabs data-code-sync="language">' +
              '<div class="example-panel__header example-panel__header--nested">' +
                '<div class="code-tabs" role="tablist" aria-label="Code examples">' +
                  supportedExampleLanguages.map(function (language) {
                    return '<button type="button" role="tab" aria-selected="' + (language === defaultLanguage ? 'true' : 'false') + '" class="code-tab' + (language === defaultLanguage ? ' is-active' : '') + '" data-code-tab="' + escapeHtml(language) + '">' + escapeHtml(language) + '</button>';
                  }).join('') +
                '</div>' +
              '</div>' +
              supportedExampleLanguages.map(function (language) {
                return '<div role="tabpanel" aria-hidden="' + (language === defaultLanguage ? 'false' : 'true') + '" class="code-pane' + (language === defaultLanguage ? ' is-active' : '') + '" data-code-pane="' + escapeHtml(language) + '" data-example-base-url="' + escapeHtml(requestData.baseUrl) + '"><pre><code>' + escapeHtml(renderRequestExample(language, requestData)) + '</code></pre></div>';
              }).join('') +
            '</section>' +
          '</div>';
        }).join('') +
      '</section>';
    }

    function renderTryItMultipartField(propertyName, schema, exampleValue, encoding, required) {
      const fieldToken = 'multipart:' + propertyName;
      const label = escapeHtml(propertyName) + (required ? ' <strong>*</strong>' : '');
      const contentTypeNote = encoding && encoding.contentType
        ? '<span class="try-it-field__meta">Sent as <code>' + escapeHtml(encoding.contentType) + '</code></span>'
        : '';

      if (schema && schema.type === 'string' && schema.format === 'binary') {
        return '<label class="try-it-field">' +
          '<span class="try-it-field__label">' + label + '</span>' +
          '<input class="try-it-field__control" type="file" data-try-it-param="' + escapeHtml(fieldToken) + '"' + (required ? ' data-try-it-required="true"' : '') + ' />' +
          '<span class="try-it-field__meta">' + (exampleValue ? 'Example file: <code>' + escapeHtml(String(exampleValue)) + '</code>' : 'Choose a local file to send.') + '</span>' +
          contentTypeNote +
        '</label>';
      }

      if (schema && (schema.type === 'object' || schema.type === 'array')) {
        return '<label class="try-it-field">' +
          '<span class="try-it-field__label">' + label + '</span>' +
          '<textarea class="try-it-field__control try-it-field__control--textarea try-it-field__control--compact" data-try-it-param="' + escapeHtml(fieldToken) + '"' + (required ? ' data-try-it-required="true"' : '') + '>' + escapeHtml(JSON.stringify(exampleValue !== undefined ? exampleValue : getSchemaDerivedExample(schema), null, 2)) + '</textarea>' +
          contentTypeNote +
        '</label>';
      }

      return '<label class="try-it-field">' +
        '<span class="try-it-field__label">' + label + '</span>' +
        '<input class="try-it-field__control" type="text" data-try-it-param="' + escapeHtml(fieldToken) + '" value="' + escapeHtml(String(exampleValue !== undefined ? exampleValue : getScalarExample(schema, propertyName) || '')) + '"' + (required ? ' data-try-it-required="true"' : '') + ' />' +
        contentTypeNote +
      '</label>';
    }

    function renderOptionalTryItToggle(itemsMarkup, count, sectionLabel) {
      if (!itemsMarkup || !count) {
        return '';
      }

      return '<details class="try-it-panel__optional">' +
        '<summary class="try-it-panel__optional-summary">Show optional ' + escapeHtml(sectionLabel) + ' (' + count + ')</summary>' +
        '<div class="try-it-panel__optional-body">' + itemsMarkup + '</div>' +
      '</details>';
    }

    function renderTryItBodyEditor(operation) {
      const requestBody = operation && operation.requestBody ? operation.requestBody : null;
      const content = requestBody && requestBody.content && requestBody.content.length ? requestBody.content[0] : null;
      if (!content) {
        return '';
      }

      const requestBodyExample = getRequestBodyExample(requestBody);
      const mediaType = content.mediaType || '';

      if (mediaType.indexOf('multipart/form-data') === 0) {
        const schema = content.schema || {};
        const properties = schema.properties || {};
        const required = Array.isArray(schema.required) ? schema.required : [];
        const exampleValue = requestBodyExample && requestBodyExample.value && typeof requestBodyExample.value === 'object'
          ? requestBodyExample.value
          : {};
        const requiredFields = [];
        const optionalFields = [];

        Object.keys(properties).forEach(function (propertyName) {
          const fieldMarkup = renderTryItMultipartField(
            propertyName,
            properties[propertyName],
            exampleValue[propertyName],
            content.encoding && content.encoding[propertyName],
            required.indexOf(propertyName) !== -1
          );

          if (required.indexOf(propertyName) !== -1) {
            requiredFields.push(fieldMarkup);
            return;
          }

          optionalFields.push(fieldMarkup);
        });

        return '<div class="try-it-panel__group">' +
          '<h4>Body</h4>' +
          '<p class="try-it-panel__body-meta"><code>' + escapeHtml(mediaType) + '</code></p>' +
          (requiredFields.length ? '<div class="try-it-panel__fields">' + requiredFields.join('') + '</div>' : '') +
          renderOptionalTryItToggle(
            optionalFields.length ? '<div class="try-it-panel__fields">' + optionalFields.join('') + '</div>' : '',
            optionalFields.length,
            'body fields'
          ) +
        '</div>';
      }

      return requestBodyExample
        ? '<div class="try-it-panel__group">' +
            '<h4>Body</h4>' +
            '<label class="try-it-field">' +
              '<span class="try-it-field__label">' + escapeHtml(requestBodyExample.mediaType || 'request body') + '</span>' +
              '<textarea class="try-it-field__control try-it-field__control--textarea" data-try-it-body>' + escapeHtml(JSON.stringify(requestBodyExample.value, null, 2)) + '</textarea>' +
            '</label>' +
          '</div>'
        : '';
    }

    function renderTryItPanel(operation) {
      const parameterGroups = [
        { key: 'path', label: 'Path parameters' },
        { key: 'query', label: 'Query parameters' },
        { key: 'header', label: 'Header parameters' },
        { key: 'cookie', label: 'Cookie parameters' }
      ];
      const parameterMarkup = parameterGroups.map(function (group) {
        const parameters = operation.parameters && operation.parameters[group.key] ? operation.parameters[group.key] : [];
        if (!parameters.length) {
          return '';
        }

        const requiredFields = [];
        const optionalFields = [];

        parameters.forEach(function (parameter) {
          const fieldMarkup = '<label class="try-it-field">' +
            '<span class="try-it-field__label">' + escapeHtml(parameter.name) + (parameter.required ? ' <strong>*</strong>' : '') + '</span>' +
            '<input class="try-it-field__control" type="text" data-try-it-param="' + escapeHtml(parameter.in + ':' + parameter.name) + '" value="' + escapeHtml(String(getParameterExample(parameter) || '')) + '" placeholder="' + escapeHtml(parameter.description || parameter.name) + '" />' +
          '</label>';

          if (parameter.required) {
            requiredFields.push(fieldMarkup);
            return;
          }

          optionalFields.push(fieldMarkup);
        });

        return '<div class="try-it-panel__group">' +
          '<h4>' + escapeHtml(group.label) + '</h4>' +
          (requiredFields.length ? '<div class="try-it-panel__fields">' + requiredFields.join('') + '</div>' : '') +
          renderOptionalTryItToggle(
            optionalFields.length ? '<div class="try-it-panel__fields">' + optionalFields.join('') + '</div>' : '',
            optionalFields.length,
            group.label.toLowerCase()
          ) +
        '</div>';
      }).join('');
      const bodyMarkup = renderTryItBodyEditor(operation);

      return '<section class="try-it-panel" data-try-it-panel data-operation-id="' + escapeHtml(operation.id) + '">' +
        '<div class="try-it-panel__header">' +
          '<div>' +
            '<h3>Try It</h3>' +
            '<p class="try-it-panel__hint">Runs in your browser against the active server and requires CORS support.</p>' +
          '</div>' +
          '<div class="try-it-panel__actions">' +
            '<button type="button" class="ui-btn ui-btn--ghost ui-btn--sm" data-try-it-reset>Reset</button>' +
            '<button type="button" class="ui-btn ui-btn--accent ui-btn--sm" data-try-it-send>Send request</button>' +
          '</div>' +
        '</div>' +
        (parameterMarkup || bodyMarkup
          ? '<div class="try-it-panel__editor">' + parameterMarkup + bodyMarkup + '</div>'
          : '') +
        '<div class="try-it-panel__preview">' +
          '<div class="try-it-panel__preview-header">' +
            '<h4>Request Preview</h4>' +
            '<span class="try-it-panel__preview-hint">Updates before send</span>' +
          '</div>' +
          '<pre class="try-it-panel__preview-code" data-try-it-preview><code></code></pre>' +
        '</div>' +
        '<div class="try-it-panel__status" data-try-it-status role="status" aria-live="polite">Ready to send.</div>' +
        '<div class="try-it-panel__response" data-try-it-response hidden aria-live="polite">' +
          '<div class="try-it-panel__response-meta">' +
            '<div class="try-it-panel__response-card">' +
              '<span class="try-it-panel__response-label">Status</span>' +
              '<code data-try-it-response-status>Ready</code>' +
            '</div>' +
            '<div class="try-it-panel__response-card">' +
              '<span class="try-it-panel__response-label">Timing</span>' +
              '<code data-try-it-response-timing>-</code>' +
            '</div>' +
          '</div>' +
          '<div class="try-it-panel__response-block">' +
            '<div class="try-it-panel__preview-header">' +
              '<h4>Response Headers</h4>' +
            '</div>' +
            '<pre class="try-it-panel__response-code"><code data-try-it-response-headers></code></pre>' +
          '</div>' +
          '<div class="try-it-panel__response-block">' +
            '<div class="try-it-panel__preview-header">' +
              '<h4>Response Body</h4>' +
            '</div>' +
            '<pre class="try-it-panel__response-code"><code data-try-it-response-body></code></pre>' +
          '</div>' +
        '</div>' +
      '</section>';
    }

    function renderOperationRequestDetails(operation) {
      const detailSections = [
        renderParameterGroup('Path parameters', operation.parameters && operation.parameters.path),
        renderParameterGroup('Query parameters', operation.parameters && operation.parameters.query),
        renderParameterGroup('Header parameters', operation.parameters && operation.parameters.header),
        renderParameterGroup('Cookie parameters', operation.parameters && operation.parameters.cookie),
        renderRequestBody(operation.requestBody),
        renderLinks(operation.links),
        renderCallbacks(operation.callbacks)
      ].filter(Boolean);

      if (!detailSections.length) {
        return '';
      }

      return '<details class="operation-card__details">' +
        '<summary class="operation-card__details-summary">' +
          '<div class="operation-card__section-header">' +
            '<h5>Request Details</h5>' +
            '<p>Parameters, body schemas, and integration wiring for this operation.</p>' +
          '</div>' +
        '</summary>' +
        '<div class="operation-card__details-body">' + detailSections.join('') + '</div>' +
      '</details>';
