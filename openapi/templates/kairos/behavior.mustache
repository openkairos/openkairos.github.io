<script>
  (function () {
    const body = document.body;
    const menuToggle = document.getElementById('menu-toggle');
    const scrollToTopButton = document.getElementById('scroll-to-top');
    const sidebar = document.getElementById('sidebar-nav');
    const overlay = document.getElementById('mobile-overlay');
    let navLinks = [];
    let headings = [];
    let linkByHash = {};
    let collapsibleTriggers = [];
    let variantGroups = [];
    let tabGroups = Array.from(document.querySelectorAll('[data-code-tabs]'));
    let languageTabGroups = tabGroups.filter(function (group) {
      return group.getAttribute('data-code-sync') === 'language';
    });
    const mainContent = document.querySelector('main.content');
    const renderModelUrl = mainContent ? mainContent.getAttribute('data-render-model-url') : null;
    let copyButtons = Array.from(document.querySelectorAll('[data-copy-example]'));
    const markdownLinkDescriptions = Array.from(document.querySelectorAll('[data-render-md-links]'));
    const overviewTitle = document.querySelector('[data-overview-title]');
    const overviewDescription = document.querySelector('[data-overview-description]');
    const overviewVersion = document.querySelector('[data-overview-version]');
    const overviewLicense = document.querySelector('[data-overview-license]');
    const overviewTerms = document.querySelector('[data-overview-terms]');
    const overviewContact = document.querySelector('[data-overview-contact]');
    const overviewExternalDocs = document.querySelector('[data-overview-external-docs]');
    const overviewDownload = document.querySelector('[data-download-spec]');
    const serverNavItem = document.querySelector('[data-server-nav-item]');
    const authenticationSection = document.querySelector('[data-authentication-section]');
    const authenticationControls = document.querySelector('[data-authentication-controls]');
    const authenticationList = document.querySelector('[data-authentication-list]');
    const authenticationNavItem = document.querySelector('[data-authentication-nav-item]');
    const operationsNavItem = document.querySelector('[data-operations-nav-item]');
    const operationsNavGroup = document.querySelector('[data-operations-nav-group]');
    const operationsNavList = document.querySelector('[data-operations-nav-list]');
    const webhooksNavItem = document.querySelector('[data-webhooks-nav-item]');
    const webhooksNavGroup = document.querySelector('[data-webhooks-nav-group]');
    const webhooksNavList = document.querySelector('[data-webhooks-nav-list]');
    const componentsNavItem = document.querySelector('[data-components-nav-item]');
    const componentsNavGroup = document.querySelector('[data-components-nav-group]');
    const componentsNavList = document.querySelector('[data-components-nav-list]');
    const operationsSection = document.querySelector('[data-operations-section]');
    const operationsGrid = document.querySelector('[data-operations-grid]');
    const webhooksSection = document.querySelector('[data-webhooks-section]');
    const webhooksGrid = document.querySelector('[data-webhooks-grid]');
    const componentsSection = document.querySelector('[data-components-section]');
    const componentsGrid = document.querySelector('[data-components-grid]');
    let serverManager = document.querySelector('[data-server-manager]');
    let serverManagerContent = serverManager ? serverManager.querySelector('[data-server-manager-content]') : null;
    let serverSelect = serverManager ? serverManager.querySelector('[data-server-select]') : null;
    let serverCards = serverManager ? Array.from(serverManager.querySelectorAll('[data-server-option]')) : [];
    let serverSummary = serverManager ? serverManager.querySelector('[data-server-summary]') : null;
    const languageStorageKey = 'kairos.docs.language';
    const serverStorageKey = 'kairos.docs.server';
    const defaultLanguage = 'curl';
    const supportedExampleLanguages = ['curl', 'python', 'javascript', 'ruby', 'php', 'java'];

    let activeHash = null;
    let scrollTicking = false;
    let activeAuthSchemeId = null;
    let currentRenderModel = null;
    let authState = {};
    let knownServerBases = [
      'https://api.kairos.dev',
      'https://api.kairos.example',
      'http://api.kairos.example'
    ];

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function createMetaItem(iconPath, label, contentHtml) {
      return '<span class="doc-meta__icon" aria-hidden="true">' +
        '<svg viewBox="0 0 24 24" width="14" height="14" focusable="false">' +
        '<path fill="currentColor" d="' + iconPath + '"></path>' +
        '</svg>' +
        '</span>' +
        '<span><strong>' + escapeHtml(label) + ':</strong> ' + contentHtml + '</span>';
    }

    function setMetaItemContent(container, iconPath, label, contentHtml) {
      if (!container || !contentHtml) {
        return;
      }

      container.className = 'doc-meta__item';
      container.innerHTML = createMetaItem(iconPath, label, contentHtml);
    }

    function slugify(value) {
      return String(value || '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');
    }

    function getOperationAnchorId(operation, prefix) {
      const base = operation.summary || [operation.method, operation.path].filter(Boolean).join(' ') || operation.id;
      return (prefix || 'operation') + '-' + slugify(base);
    }

    function getComponentAnchorId(item, kind) {
      return 'component-' + slugify(kind + ' ' + (item.name || item.id));
    }

    function normalizeHash(hash) {
      if (!hash) {
        return '';
      }
      return hash.charAt(0) === '#' ? hash : ('#' + hash);
    }

    function getHeadingByHash(hash) {
      const normalizedHash = normalizeHash(hash);
      if (!normalizedHash) {
        return null;
      }
      return document.getElementById(normalizedHash.slice(1));
    }

    function updateDocumentHash(hash, options) {
      const normalizedHash = normalizeHash(hash);
      const currentHash = normalizeHash(window.location.hash);
      const opts = options || {};
      const nextUrl = normalizedHash
        ? window.location.pathname + window.location.search + normalizedHash
        : window.location.pathname + window.location.search;

      if (normalizedHash === currentHash) {
        return;
      }

      if (opts.replace) {
        window.history.replaceState(null, '', nextUrl);
        return;
      }

      window.location.hash = normalizedHash;
    }

    function scrollToHash(hash) {
      const target = getHeadingByHash(hash);
      if (!target) {
        return false;
      }
      target.scrollIntoView({block: 'start'});
      return true;
    }

    function navigateToHash(hash, options) {
      const normalizedHash = normalizeHash(hash);
      const opts = options || {};
      if (!normalizedHash) {
        return false;
      }

      if (!getHeadingByHash(normalizedHash) && !linkByHash[normalizedHash]) {
        return false;
      }

      setActiveLinkByHash(normalizedHash, {
        force: true,
        skipSidebarScroll: !!opts.skipSidebarScroll
      });

      if (!opts.skipDocumentHash) {
        updateDocumentHash(normalizedHash, {replace: !!opts.replaceHistory});
      }

      if (!opts.skipScroll) {
        scrollToHash(normalizedHash);
      }

      return true;
    }

    function getSectionHash(hash) {
      const normalizedHash = normalizeHash(hash);
      if (!normalizedHash) {
        return '';
      }
      if (
        normalizedHash === '#overview' ||
        normalizedHash === '#servers' ||
        normalizedHash === '#authentication' ||
        normalizedHash === '#operations' ||
        normalizedHash === '#webhooks' ||
        normalizedHash === '#components'
      ) {
        return normalizedHash;
      }
      if (normalizedHash.indexOf('#operations-tag-') === 0 || normalizedHash.indexOf('#operation-') === 0) {
        return '#operations';
      }
      if (normalizedHash.indexOf('#webhook-group-') === 0 || normalizedHash.indexOf('#webhook-') === 0) {
        return '#webhooks';
      }
      if (normalizedHash.indexOf('#components-') === 0 || normalizedHash.indexOf('#component-') === 0) {
        return '#components';
      }
      return '';
    }

    function refreshNavigationCollections() {
      navLinks = Array.from(document.querySelectorAll('.menu__link[href^="#"]'));
      headings = Array.from(document.querySelectorAll('main .anchor[id]'));
      linkByHash = navLinks.reduce(function (acc, link) {
        acc[link.getAttribute('href')] = link;
        return acc;
      }, {});
      collapsibleTriggers = Array.from(
        document.querySelectorAll('.menu__list-item-collapsible .menu__caret')
      );
    }

    function refreshVariantCollections() {
      variantGroups = Array.from(document.querySelectorAll('[data-variant-group]'));
    }

    function refreshServerCollections() {
      serverManager = document.querySelector('[data-server-manager]');
      serverManagerContent = serverManager ? serverManager.querySelector('[data-server-manager-content]') : null;
      serverSelect = serverManager ? serverManager.querySelector('[data-server-select]') : null;
      serverCards = serverManager ? Array.from(serverManager.querySelectorAll('[data-server-option]')) : [];
      serverSummary = serverManager ? serverManager.querySelector('[data-server-summary]') : null;
    }

    function syncTryItShellsForViewport() {
      const isMobileViewport = window.matchMedia('(max-width: 840px)').matches;
      Array.from(document.querySelectorAll('.try-it-shell')).forEach(function (shell) {
        if (!shell.__kairosViewportInitialized) {
          shell.__kairosViewportInitialized = true;
          if (isMobileViewport) {
            shell.removeAttribute('open');
            return;
          }
          shell.setAttribute('open', '');
          return;
        }

        if (isMobileViewport) {
          return;
        }

        shell.setAttribute('open', '');
      });
    }

    function syncCollapsibleTriggerState(trigger) {
      if (!trigger) {
        return;
      }
      const listItem = trigger.closest('.menu__list-item');
      if (!listItem) {
        return;
      }
      trigger.setAttribute('aria-expanded', listItem.classList.contains('menu__list-item--collapsed') ? 'false' : 'true');
    }

    function bindNavigationInteractions() {
      collapsibleTriggers.forEach(function (trigger) {
        if (trigger.__kairosBound) {
          syncCollapsibleTriggerState(trigger);
          return;
        }
        trigger.__kairosBound = true;
        syncCollapsibleTriggerState(trigger);
        trigger.addEventListener('click', function (event) {
          const listItem = trigger.closest('.menu__list-item');
          if (!listItem) {
            return;
          }
          event.preventDefault();
          listItem.classList.toggle('menu__list-item--collapsed');
          syncCollapsibleTriggerState(trigger);
        });
      });

      navLinks.forEach(function (link) {
        if (link.__kairosBound) {
          return;
        }
        link.__kairosBound = true;
        link.addEventListener('click', function (event) {
          const hash = link.getAttribute('href');
          event.preventDefault();
          navigateToHash(hash);
          if (window.matchMedia('(max-width: 840px)').matches) {
            closeSidebar();
          }
        });
      });
    }

    function hydrateOverview(renderModel) {
      const meta = renderModel && renderModel.meta ? renderModel.meta : null;
      if (!meta) {
        return;
      }

      if (overviewTitle && meta.title) {
        overviewTitle.textContent = meta.title;
      }

      if (overviewDescription && meta.description) {
        overviewDescription.textContent = meta.description;
      }

      if (overviewVersion && meta.version) {
        setMetaItemContent(
          overviewVersion,
          'M5 5h14v2H5zm0 6h8v2H5zm0 6h14v2H5z',
          'Version',
          escapeHtml(meta.version)
        );
      }

      if (overviewLicense && meta.license && meta.license.name) {
        const licenseContent = meta.license.url
          ? '<a href="' + escapeHtml(meta.license.url) + '" class="doc-meta__link" target="_blank" rel="noopener noreferrer">' + escapeHtml(meta.license.name) + '</a>'
          : escapeHtml(meta.license.name);
        setMetaItemContent(
          overviewLicense,
          'M12 2l8 4v6c0 5-3.4 9.5-8 10-4.6-.5-8-5-8-10V6zm0 2.2L6 7v5c0 3.8 2.4 7.4 6 8.4 3.6-1 6-4.6 6-8.4V7z',
          'License',
          licenseContent
        );
      }

      if (overviewTerms && meta.termsOfService) {
        setMetaItemContent(
          overviewTerms,
          'M7 4h10v2H7zm-2 4h14v2H5zm2 4h10v2H7zm-2 4h14v2H5z',
          'Terms',
          '<a href="' + escapeHtml(meta.termsOfService) + '" class="doc-meta__link" target="_blank" rel="noopener noreferrer">Terms of service</a>'
        );
      }

      if (overviewContact && meta.contact && (meta.contact.name || meta.contact.email || meta.contact.url)) {
        const contactParts = [];
        if (meta.contact.url && meta.contact.name) {
          contactParts.push('<a href="' + escapeHtml(meta.contact.url) + '" class="doc-meta__link" target="_blank" rel="noopener noreferrer">' + escapeHtml(meta.contact.name) + '</a>');
        } else if (meta.contact.name) {
          contactParts.push(escapeHtml(meta.contact.name));
        }
        if (meta.contact.email) {
          contactParts.push('<a href="mailto:' + escapeHtml(meta.contact.email) + '" class="doc-meta__link">' + escapeHtml(meta.contact.email) + '</a>');
        }
        setMetaItemContent(
          overviewContact,
          'M21 8V7l-3 2-2-1-4 3-4-3-2 1-3-2v1l9 6zm0 2-9 6-9-6V18h18z',
          'Contact',
          contactParts.join(' ')
        );
      }

      if (overviewExternalDocs && meta.externalDocs && meta.externalDocs.url) {
        setMetaItemContent(
          overviewExternalDocs,
          'M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3zM5 5h6v2H7v10h10v-4h2v6H5V5z',
          'Docs',
          '<a href="' + escapeHtml(meta.externalDocs.url) + '" class="doc-meta__link" target="_blank" rel="noopener noreferrer">' + escapeHtml(meta.externalDocs.description || 'External docs') + '</a>'
        );
      }

      if (overviewDownload && renderModel && renderModel.download && renderModel.download.assetPath) {
        overviewDownload.hidden = false;
        overviewDownload.setAttribute('href', new URL(renderModel.download.assetPath, window.location.href).toString());
        overviewDownload.setAttribute('download', renderModel.download.fileName || 'openapi.yaml');
      }
    }

    function stringifyValue(value) {
      if (value === null || value === undefined) {
        return '';
      }
      if (typeof value === 'string') {
        return value;
      }
      return JSON.stringify(value, null, 2);
    }

    function formatJsonScalar(value) {
      if (value === null) {
        return 'null';
      }
      if (typeof value === 'string') {
        return '"' + value + '"';
      }
      if (typeof value === 'boolean') {
        return value ? 'true' : 'false';
      }
      return String(value);
    }

    function getJsonSummary(value) {
      if (Array.isArray(value)) {
        return '[' + value.length + ' item' + (value.length === 1 ? '' : 's') + ']';
      }
      if (value && typeof value === 'object') {
        const count = Object.keys(value).length;
        return '{' + count + ' key' + (count === 1 ? '' : 's') + '}';
      }

      const scalar = formatJsonScalar(value);
      return scalar.length > 40 ? scalar.slice(0, 37) + '...' : scalar;
    }

    function renderJsonTreeValue(name, value) {
      const hasName = name !== null && name !== undefined && name !== '';

      if (Array.isArray(value)) {
        return '<details class="json-tree__node">' +
          '<summary class="json-tree__summary">' +
            (hasName ? '<span class="json-tree__key">' + escapeHtml(String(name)) + '</span>' : '<span class="json-tree__key">Array</span>') +
            '<span class="json-tree__meta">' + escapeHtml(getJsonSummary(value)) + '</span>' +
          '</summary>' +
          '<div class="json-tree__children">' +
            (value.length
              ? value.map(function (item, index) {
                  return renderJsonTreeValue(index, item);
                }).join('')
              : '<div class="json-tree__empty">No items</div>') +
          '</div>' +
        '</details>';
      }

      if (value && typeof value === 'object') {
        const entries = Object.entries(value);
        return '<details class="json-tree__node">' +
          '<summary class="json-tree__summary">' +
            (hasName ? '<span class="json-tree__key">' + escapeHtml(String(name)) + '</span>' : '<span class="json-tree__key">Object</span>') +
            '<span class="json-tree__meta">' + escapeHtml(getJsonSummary(value)) + '</span>' +
          '</summary>' +
          '<div class="json-tree__children">' +
            (entries.length
              ? entries.map(function (entry) {
                  return renderJsonTreeValue(entry[0], entry[1]);
                }).join('')
              : '<div class="json-tree__empty">No properties</div>') +
          '</div>' +
        '</details>';
      }

      return '<div class="json-tree__leaf">' +
        (hasName ? '<span class="json-tree__key">' + escapeHtml(String(name)) + '</span>' : '<span class="json-tree__key">Value</span>') +
        '<code class="json-tree__value">' + escapeHtml(formatJsonScalar(value)) + '</code>' +
      '</div>';
    }

    function renderJsonExplorer(title, value) {
      if (value === null || value === undefined || value === '') {
        return '';
      }

      return '<section class="json-raw">' +
        '<div class="json-raw__header">' + escapeHtml(title) + '</div>' +
        '<pre class="json-raw__body"><code>' + escapeHtml(JSON.stringify(value, null, 2)) + '</code></pre>' +
      '</section>';
    }

    function summarizeSchema(item) {
      if (!item) {
        return '';
      }
      if (item.schemaRef) {
        return '<code>' + escapeHtml(item.schemaRef) + '</code>';
      }
      if (!item.schema) {
        return '';
      }
      if (item.schema.type) {
        return '<code>' + escapeHtml(Array.isArray(item.schema.type) ? item.schema.type.join(' | ') : item.schema.type) + '</code>';
      }
      if (item.schema.oneOf) {
        return '<code>oneOf</code>';
      }
      if (item.schema.anyOf) {
        return '<code>anyOf</code>';
      }
      if (item.schema.allOf) {
        return '<code>allOf</code>';
      }
      return '<code>schema</code>';
    }

    function renderParameterGroup(title, parameters) {
      if (!parameters || !parameters.length) {
        return '';
      }

      return '<div class="card table-wrap">' +
        '<h4>' + escapeHtml(title) + '</h4>' +
        '<table>' +
        '<thead><tr><th>Name</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>' +
        '<tbody>' +
        parameters.map(function (parameter) {
          return '<tr>' +
            '<td><code>' + escapeHtml(parameter.name) + '</code></td>' +
            '<td>' + summarizeSchema(parameter) + '</td>' +
            '<td>' + (parameter.required ? 'yes' : 'no') + '</td>' +
            '<td>' + escapeHtml(parameter.description || '') + '</td>' +
            '</tr>';
        }).join('') +
        '</tbody>' +
        '</table>' +
        '</div>';
    }

    function renderRequestBody(requestBody) {
      if (!requestBody) {
        return '';
      }

      return requestBody.content.map(function (content) {
        const example = content.examples && content.examples.length ? content.examples[0] : null;
        return '<div class="card operation-content-card">' +
          '<h4>Request Body <code>' + escapeHtml(content.mediaType) + '</code></h4>' +
          (requestBody.description ? '<p class="operation-card__text">' + escapeHtml(requestBody.description) + '</p>' : '') +
          '<p class="operation-card__meta-line"><strong>Schema:</strong> ' + summarizeSchema(content) + '</p>' +
          renderJsonExplorer('Schema', content.schema) +
          (example ? renderJsonExplorer('Example', example.value) : '') +
          '</div>';
      }).join('');
    }

    function renderVariantSelector(variants, options) {
      const opts = options || {};
      if (!variants || variants.length <= 1) {
        return '';
      }

      return '<div class="variant-tabs" data-variant-group="' + escapeHtml(opts.groupId || '') + '">' +
        variants.map(function (variant, index) {
          const label = variant.summary || variant.id || ('Variant ' + (index + 1));
          return '<button type="button" role="tab" aria-selected="' + (index === 0 ? 'true' : 'false') + '" class="variant-tab' + (index === 0 ? ' is-active' : '') + '" data-variant-button="' + escapeHtml(variant.id || String(index)) + '">' + escapeHtml(label) + '</button>';
        }).join('') +
        '</div>';
    }

    function renderResponses(responses) {
      if (!responses || !responses.length) {
        return '';
      }

      return '<div class="operation-responses">' +
        responses.map(function (response) {
          const firstContent = response.content && response.content.length ? response.content[0] : null;
          const examples = firstContent && firstContent.examples ? firstContent.examples : [];
          return '<div class="card operation-response-card">' +
            '<h4><code>' + escapeHtml(response.statusCode) + '</code> ' + escapeHtml(response.description || '') + '</h4>' +
            (response.headers && response.headers.length
              ? '<p class="operation-card__meta-line"><strong>Headers:</strong> ' + response.headers.map(function (header) {
                  return '<code>' + escapeHtml(header.name) + '</code>';
                }).join(', ') + '</p>'
              : '') +
            (firstContent
              ? '<p class="operation-card__meta-line"><strong>Body:</strong> <code>' + escapeHtml(firstContent.mediaType) + '</code> ' + summarizeSchema(firstContent) + '</p>'
              : '') +
            (firstContent && firstContent.schema ? renderJsonExplorer('Schema', firstContent.schema) : '') +
            renderVariantSelector(examples, { groupId: 'response-' + escapeHtml(response.statusCode) }) +
            (examples.length
              ? examples.map(function (example, index) {
                  return '<div class="variant-pane' + (index === 0 ? ' is-active' : '') + '" data-variant-pane="' + escapeHtml(example.id || String(index)) + '">' +
                    renderJsonExplorer(example.summary || example.id || 'Example', example.value) +
                    '</div>';
                }).join('')
              : '') +
            '</div>';
        }).join('') +
        '</div>';
    }

    function renderSecurity(security) {
      if (!security || !security.length) {
        return '<p class="operation-card__meta-line"><strong>Authentication:</strong> None</p>';
      }

      return '<p class="operation-card__meta-line"><strong>Authentication:</strong> ' + security.map(function (requirement) {
        return requirement.schemeIds.map(function (id) {
          return '<code>' + escapeHtml(id) + '</code>';
        }).join(', ');
      }).join(' or ') + '</p>';
    }

    function formatAuthMeta(scheme) {
      if (!scheme) {
        return '';
      }
      if (scheme.location && scheme.location.kind && scheme.location.name) {
        return escapeHtml(scheme.location.name + ' ' + scheme.location.kind);
      }
      if (scheme.type === 'oauth2') {
        return 'OAuth 2.0 flows';
      }
      if (scheme.type === 'openIdConnect') {
        return 'Discovery document';
      }
      return escapeHtml(scheme.type || '');
    }

    function dedupeScopes(scopes) {
      const seen = {};
      return (scopes || []).filter(function (scope) {
        if (!scope || !scope.name || seen[scope.name]) {
          return false;
        }
        seen[scope.name] = true;
        return true;
      });
    }

    function renderAuthFlows(flows) {
      if (!flows || !flows.length) {
        return '';
      }

      return '<div class="auth-item__scopes"><h4>Flows</h4><ul>' +
        flows.map(function (flow) {
          const parts = [
            flow.authorizationUrl ? 'auth: ' + flow.authorizationUrl : null,
            flow.tokenUrl ? 'token: ' + flow.tokenUrl : null,
            flow.refreshUrl ? 'refresh: ' + flow.refreshUrl : null
          ].filter(Boolean);
          return '<li><strong>' + escapeHtml(flow.name) + '</strong>' +
            (parts.length ? '<div>' + parts.map(function (part) { return '<code>' + escapeHtml(part) + '</code>'; }).join(' ') + '</div>' : '') +
            '</li>';
        }).join('') +
        '</ul></div>';
    }

    function renderAuthSchemeDetails(scheme) {
      if (!scheme) {
        return '';
      }

      if (scheme.type === 'http') {
        return '<p class="operation-card__meta-line"><strong>HTTP scheme:</strong> <code>' + escapeHtml(scheme.scheme || 'http') + '</code></p>' +
          (scheme.location
            ? '<p class="operation-card__meta-line"><strong>Header:</strong> <code>' + escapeHtml(scheme.location.name) + '</code></p>'
            : '');
      }

      if (scheme.type === 'apiKey') {
        return '<p class="operation-card__meta-line"><strong>Location:</strong> <code>' + escapeHtml(scheme.location ? scheme.location.kind : '') + '</code></p>' +
          '<p class="operation-card__meta-line"><strong>Name:</strong> <code>' + escapeHtml(scheme.location ? scheme.location.name : '') + '</code></p>';
      }

      if (scheme.type === 'oauth2') {
        return '<p class="operation-card__meta-line"><strong>Type:</strong> OAuth 2.0</p>' + renderAuthFlows(scheme.flows);
      }

      if (scheme.type === 'openIdConnect') {
        return '<p class="operation-card__meta-line"><strong>Type:</strong> OpenID Connect</p>' +
          (scheme.openIdConnectUrl
            ? '<p class="operation-card__meta-line"><strong>Discovery URL:</strong> <a class="doc-meta__link" href="' + escapeHtml(scheme.openIdConnectUrl) + '" target="_blank" rel="noopener noreferrer">' + escapeHtml(scheme.openIdConnectUrl) + '</a></p>'
            : '');
      }

      return '';
    }

    function getAuthFieldValue(schemeId, fieldName, fallbackValue) {
      if (!authState[schemeId]) {
        authState[schemeId] = {};
      }
      if (Object.prototype.hasOwnProperty.call(authState[schemeId], fieldName)) {
        return authState[schemeId][fieldName];
      }
      return fallbackValue || '';
    }

    function renderAuthInputs(scheme) {
      if (!scheme) {
        return '';
      }

      if (scheme.type === 'http' && scheme.scheme === 'bearer') {
        return '<div class="auth-inputs">' +
          '<label class="auth-input">' +
            '<span class="auth-input__label">Access token</span>' +
            '<input class="auth-input__control" type="text" data-auth-input="' + escapeHtml(scheme.id) + ':token" value="' + escapeHtml(getAuthFieldValue(scheme.id, 'token', '')) + '" placeholder="YOUR_TOKEN" />' +
          '</label>' +
        '</div>';
      }

      if (scheme.type === 'http' && scheme.scheme === 'basic') {
        return '<div class="auth-inputs auth-inputs--two">' +
          '<label class="auth-input">' +
            '<span class="auth-input__label">Username</span>' +
            '<input class="auth-input__control" type="text" data-auth-input="' + escapeHtml(scheme.id) + ':username" value="' + escapeHtml(getAuthFieldValue(scheme.id, 'username', '')) + '" placeholder="username" />' +
          '</label>' +
          '<label class="auth-input">' +
            '<span class="auth-input__label">Password</span>' +
            '<input class="auth-input__control" type="password" data-auth-input="' + escapeHtml(scheme.id) + ':password" value="' + escapeHtml(getAuthFieldValue(scheme.id, 'password', '')) + '" placeholder="password" />' +
          '</label>' +
        '</div>';
      }

      if (scheme.type === 'apiKey') {
        return '<div class="auth-inputs">' +
          '<label class="auth-input">' +
            '<span class="auth-input__label">' + escapeHtml((scheme.location && scheme.location.name) || 'API key') + '</span>' +
            '<input class="auth-input__control" type="text" data-auth-input="' + escapeHtml(scheme.id) + ':value" value="' + escapeHtml(getAuthFieldValue(scheme.id, 'value', '')) + '" placeholder="YOUR_API_KEY" />' +
          '</label>' +
        '</div>';
      }

      if (scheme.type === 'oauth2') {
        const flowOptions = (scheme.flows || []).map(function (flow) {
          return '<option value="' + escapeHtml(flow.name) + '">' + escapeHtml(flow.name) + '</option>';
        }).join('');
        return '<div class="auth-inputs auth-inputs--two">' +
          '<label class="auth-input">' +
            '<span class="auth-input__label">Flow</span>' +
            '<select class="auth-input__control" data-auth-input="' + escapeHtml(scheme.id) + ':flow">' +
              flowOptions +
            '</select>' +
          '</label>' +
          '<label class="auth-input">' +
            '<span class="auth-input__label">Access token</span>' +
            '<input class="auth-input__control" type="text" data-auth-input="' + escapeHtml(scheme.id) + ':token" value="' + escapeHtml(getAuthFieldValue(scheme.id, 'token', '')) + '" placeholder="YOUR_ACCESS_TOKEN" />' +
          '</label>' +
        '</div>';
      }

      if (scheme.type === 'openIdConnect') {
        return '<div class="auth-inputs">' +
          '<label class="auth-input">' +
            '<span class="auth-input__label">ID token / access token</span>' +
            '<input class="auth-input__control" type="text" data-auth-input="' + escapeHtml(scheme.id) + ':token" value="' + escapeHtml(getAuthFieldValue(scheme.id, 'token', '')) + '" placeholder="YOUR_OPENID_TOKEN" />' +
          '</label>' +
        '</div>';
      }

      return '';
    }

    function rerenderExampleSurfaces() {
      if (!currentRenderModel) {
        return;
      }

      hydrateOperations(currentRenderModel);
      hydrateWebhooks(currentRenderModel);
      applyLanguageToAllGroups(getPreferredLanguage());
      applyServerState({skipPersistence: true});
