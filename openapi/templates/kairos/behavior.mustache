    function renderActiveAuthControls(auth) {
      if (!authenticationControls) {
        return;
      }
      const scheme = auth.schemes.find(function (item) {
        return item.id === activeAuthSchemeId;
      }) || auth.schemes[0];

      authenticationControls.innerHTML = '<div class="card auth-selector">' +
        '<label class="auth-selector__label" for="auth-scheme-select">Active authentication method</label>' +
        '<div class="auth-selector__row">' +
          '<select id="auth-scheme-select" class="server-picker__select auth-selector__select" data-auth-scheme-select>' +
            auth.schemes.map(function (item) {
              return '<option value="' + escapeHtml(item.id) + '"' + (item.id === activeAuthSchemeId ? ' selected' : '') + '>' + escapeHtml(item.displayName || item.id) + '</option>';
            }).join('') +
          '</select>' +
          '<div class="auth-selector__summary">' +
            '<span class="auth-selector__summary-label">Currently applied</span>' +
            '<code class="auth-selector__summary-value" data-auth-scheme-summary>' + escapeHtml((scheme && (scheme.displayName || scheme.id)) || '') + '</code>' +
          '</div>' +
        '</div>' +
        '<div class="auth-selector__inputs" data-auth-inputs>' +
          renderAuthInputs(scheme) +
