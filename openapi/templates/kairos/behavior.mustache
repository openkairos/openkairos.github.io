    }

    function renderAuthScheme(scheme, isOpen) {
      const scopes = dedupeScopes(scheme.scopes);
      return '<details class="auth-item' + (isOpen ? ' is-active' : '') + '" data-auth-scheme="' + escapeHtml(scheme.id) + '"' + (isOpen ? ' open' : '') + '>' +
        '<summary class="auth-item__summary">' +
          '<span class="auth-item__title">' + escapeHtml(scheme.displayName || scheme.id) + '</span>' +
          '<span class="auth-item__meta">' + formatAuthMeta(scheme) + '</span>' +
        '</summary>' +
        '<div class="auth-item__body">' +
          (scheme.description ? '<div class="auth-item__description" data-render-md-links>' + escapeHtml(scheme.description) + '</div>' : '') +
          renderAuthSchemeDetails(scheme) +
          (scopes.length
            ? '<div class="auth-item__scopes"><h4>Scopes</h4><ul>' + scopes.map(function (scope) {
                return '<li><code>' + escapeHtml(scope.name) + '</code>' + (scope.description ? ' ' + escapeHtml(scope.description) : '') + '</li>';
              }).join('') + '</ul></div>'
            : '') +
        '</div>' +
      '</details>';
    }

    function setActiveAuthScheme(schemeId) {
      activeAuthSchemeId = schemeId;
      const selector = authenticationControls ? authenticationControls.querySelector('[data-auth-scheme-select]') : null;
      const summary = authenticationControls ? authenticationControls.querySelector('[data-auth-scheme-summary]') : null;
      if (selector) {
        selector.value = schemeId;
      }

      Array.from(document.querySelectorAll('[data-auth-scheme]')).forEach(function (item) {
        const isActive = item.getAttribute('data-auth-scheme') === schemeId;
        item.classList.toggle('is-active', isActive);
        item.open = isActive;
      });

      if (summary) {
        const activeOption = selector ? selector.options[selector.selectedIndex] : null;
        summary.textContent = activeOption ? activeOption.textContent : '';
      }
    }

    function bindAuthenticationInteractions(auth) {
      renderActiveAuthControls(auth);
      const selector = authenticationControls ? authenticationControls.querySelector('[data-auth-scheme-select]') : null;
      if (selector && !selector.__kairosBound) {
        selector.__kairosBound = true;
        selector.addEventListener('change', function () {
          activeAuthSchemeId = selector.value;
          bindAuthenticationInteractions(auth);
          setActiveAuthScheme(selector.value);
          rerenderExampleSurfaces();
        });
      }

      Array.from(document.querySelectorAll('[data-auth-input]')).forEach(function (input) {
        if (input.__kairosBound) {
          return;
        }
        input.__kairosBound = true;
        const token = input.getAttribute('data-auth-input') || '';
        const parts = token.split(':');
        const schemeId = parts[0];
        const fieldName = parts[1];
        if (fieldName && input.tagName === 'SELECT') {
          const currentValue = getAuthFieldValue(schemeId, fieldName, input.value);
          input.value = currentValue || input.value;
        }
        input.addEventListener('input', function () {
          if (!authState[schemeId]) {
            authState[schemeId] = {};
          }
          authState[schemeId][fieldName] = input.value;
          rerenderExampleSurfaces();
        });
        input.addEventListener('change', function () {
          if (!authState[schemeId]) {
            authState[schemeId] = {};
          }
          authState[schemeId][fieldName] = input.value;
          rerenderExampleSurfaces();
        });
      });

      Array.from(document.querySelectorAll('[data-auth-scheme]')).forEach(function (item) {
        const summary = item.querySelector('.auth-item__summary');
        if (!summary || summary.__kairosBound) {
          return;
        }
        summary.__kairosBound = true;
        summary.addEventListener('click', function () {
          const schemeId = item.getAttribute('data-auth-scheme');
          if (schemeId) {
            window.setTimeout(function () {
              setActiveAuthScheme(schemeId);
            }, 0);
          }
        });
      });

      setActiveAuthScheme(activeAuthSchemeId || auth.defaultSchemeId || (auth.schemes[0] && auth.schemes[0].id) || '');
    }

    function hydrateAuthentication(renderModel) {
      const auth = renderModel && renderModel.auth ? renderModel.auth : null;
      const schemes = auth && Array.isArray(auth.schemes) ? auth.schemes : [];

      if (!schemes.length || !authenticationSection || !authenticationList) {
        return;
      }

      authenticationSection.hidden = false;
      if (authenticationNavItem) {
        authenticationNavItem.hidden = false;
      }
      authenticationList.innerHTML = schemes.map(function (scheme, index) {
        return renderAuthScheme(scheme, index === 0);
      }).join('');
      activeAuthSchemeId = auth.defaultSchemeId || (schemes[0] && schemes[0].id) || null;
      bindAuthenticationInteractions(auth);
      renderMarkdownLinks();
      refreshNavigationCollections();
      bindNavigationInteractions();
    }

    function renderServerVariableField(server, variable) {
      const fieldId = 'server-' + slugify(server.id + '-' + variable.name);
      if (variable.enumValues && variable.enumValues.length) {
        return '<div class="server-field">' +
          '<label class="server-field__label" for="' + escapeHtml(fieldId) + '">' + escapeHtml(variable.name) + '</label>' +
          '<select id="' + escapeHtml(fieldId) + '" class="server-field__control" data-server-variable data-server-variable-name="' + escapeHtml(variable.name) + '" data-server-default-value="' + escapeHtml(variable.defaultValue) + '">' +
          variable.enumValues.map(function (value) {
            return '<option value="' + escapeHtml(value) + '"' + (value === variable.defaultValue ? ' selected' : '') + '>' + escapeHtml(value) + '</option>';
          }).join('') +
          '</select>' +
          '<p class="server-field__meta"><span><strong>Default:</strong> <code>' + escapeHtml(variable.defaultValue) + '</code></span>' +
          (variable.description ? '<span>' + escapeHtml(variable.description) + '</span>' : '') +
          '</p>' +
          '</div>';
      }

      return '<div class="server-field">' +
        '<label class="server-field__label" for="' + escapeHtml(fieldId) + '">' + escapeHtml(variable.name) + '</label>' +
        '<input id="' + escapeHtml(fieldId) + '" class="server-field__control" type="text" value="' + escapeHtml(variable.defaultValue) + '" data-server-variable data-server-variable-name="' + escapeHtml(variable.name) + '" data-server-default-value="' + escapeHtml(variable.defaultValue) + '" />' +
        '<p class="server-field__meta"><span><strong>Default:</strong> <code>' + escapeHtml(variable.defaultValue) + '</code></span>' +
        (variable.description ? '<span>' + escapeHtml(variable.description) + '</span>' : '') +
        '</p>' +
        '</div>';
    }

    function hydrateServers(renderModel) {
      const servers = renderModel && Array.isArray(renderModel.servers) ? renderModel.servers : [];
      if (!servers.length || !serverManager || !serverManagerContent) {
        return;
      }

      serverManager.hidden = false;
      if (serverNavItem) {
