      }

      serverManagerContent.innerHTML = '<div class="card server-manager-card">' +
        '<div class="server-picker">' +
          '<div class="server-picker__toolbar">' +
            '<div class="server-picker__status">' +
              '<p class="server-picker__eyebrow">Examples Use This Server</p>' +
              '<span class="server-picker__badge">Active</span>' +
            '</div>' +
            '<div class="server-picker__intro">' +
              '<div>' +
                '<label class="server-picker__label" for="server-select">Choose the server you want to work against</label>' +
                '<p class="server-picker__hint">Request examples below update automatically. You can also customize server variables before copying an example.</p>' +
              '</div>' +
            '</div>' +
            '<select id="server-select" class="server-picker__select" data-server-select>' +
              servers.map(function (server) {
                return '<option value="' + escapeHtml(server.id) + '">' + escapeHtml(server.description || server.urlTemplate) + '</option>';
              }).join('') +
            '</select>' +
            '<div class="server-picker__summary">' +
              '<span class="server-picker__summary-label">Currently applied</span>' +
              '<code class="server-picker__summary-url" data-server-summary>' + escapeHtml(servers[0].defaultResolvedUrl) + '</code>' +
            '</div>' +
          '</div>' +
          '<div class="servers-list">' +
            servers.map(function (server, index) {
              return '<article class="server-card' + (index === 0 ? ' is-active' : '') + '" data-server-option="' + escapeHtml(server.id) + '" data-server-template="' + escapeHtml(server.urlTemplate) + '">' +
                '<div class="server-card__header">' +
                  '<h3>' + escapeHtml(server.description || 'Server') + '</h3>' +
                  '<code class="server-card__url">' + escapeHtml(server.urlTemplate) + '</code>' +
                '</div>' +
                '<p class="server-card__resolved"><strong>Resolved URL:</strong> <code data-server-resolved>' + escapeHtml(server.defaultResolvedUrl) + '</code></p>' +
                (server.variables && server.variables.length
                  ? '<div class="server-card__variables">' + server.variables.map(function (variable) {
                      return renderServerVariableField(server, variable);
