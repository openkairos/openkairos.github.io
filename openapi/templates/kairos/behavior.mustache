      }

      return '<details class="operation-card__details operation-card__details--responses" open>' +
        '<summary class="operation-card__details-summary">' +
          '<div class="operation-card__section-header">' +
            '<h5>Responses</h5>' +
            '<p>Status codes, headers, and example payloads returned by this operation.</p>' +
          '</div>' +
        '</summary>' +
        '<div class="operation-card__details-body">' + responsesMarkup + '</div>' +
      '</details>';
    }

    function renderOperationWorkspace(renderModel, operation, options) {
      const opts = options || {};
      const exampleMarkup = renderExamplePanel(renderModel, operation);
      const tryItMarkup = opts.enableTryIt === false
        ? ''
        : '<details class="try-it-shell" open>' +
            '<summary class="try-it-shell__summary">Try It</summary>' +
            renderTryItPanel(operation) +
          '</details>';
      const workspaceClassName = tryItMarkup
        ? 'api-operation api-operation--interactive'
        : 'api-operation api-operation--examples-only';

      return '<section class="operation-card__workspace ' + workspaceClassName + '">' +
        '<div class="api-operation__main">' + exampleMarkup + '</div>' +
        (tryItMarkup ? '<div class="api-operation__aside">' + tryItMarkup + '</div>' : '') +
      '</section>';
    }

    function renderOperationCard(operation, options) {
      const opts = options || {};
      const title = operation.summary || operation.id;
      const anchorPrefix = opts.anchorPrefix || 'operation';
      const anchorId = getOperationAnchorId(operation, anchorPrefix);
      const endpointLabel = opts.endpointLabel || operation.path || operation.name || '';
      const endpointMeta = opts.endpointMeta
        ? '<p class="operation-card__meta-line"><strong>' + escapeHtml(opts.endpointMeta.label) + ':</strong> <code>' + escapeHtml(opts.endpointMeta.value) + '</code></p>'
        : '';

      return '<article class="card operation-card">' +
        '<h4 class="anchor" id="' + escapeHtml(anchorId) + '">' + escapeHtml(title) +
