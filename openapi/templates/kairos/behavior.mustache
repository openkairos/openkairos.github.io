    function hydrateOperations(renderModel) {
      const operations = renderModel && Array.isArray(renderModel.operations) ? renderModel.operations.filter(function (operation) {
        return operation.kind === 'path';
      }) : [];
      const tags = renderModel && Array.isArray(renderModel.tags) ? renderModel.tags : [];

      if (!operations.length || !operationsSection || !operationsGrid) {
        return;
      }

      const groupedByTag = operations.reduce(function (acc, operation) {
        const groupNames = operation.tags && operation.tags.length ? operation.tags : ['Untagged'];
        groupNames.forEach(function (tagName) {
          acc[tagName] = acc[tagName] || [];
          acc[tagName].push(operation);
        });
        return acc;
      }, {});

      const orderedTagNames = tags.map(function (tag) {
        return tag.name;
      }).concat(Object.keys(groupedByTag).filter(function (tagName) {
        return tags.every(function (tag) {
          return tag.name !== tagName;
        });
      }));

      operationsSection.hidden = false;
      if (operationsNavItem) {
        operationsNavItem.hidden = false;
      }

      operationsGrid.innerHTML = orderedTagNames.filter(function (tagName) {
        return groupedByTag[tagName] && groupedByTag[tagName].length;
      }).map(function (tagName) {
        const tagId = slugify(tagName);
        return '<section class="operation-group">' +
          '<h3 class="anchor" id="operations-tag-' + escapeHtml(tagId) + '">' + escapeHtml(tagName) +
          '<a href="#operations-tag-' + escapeHtml(tagId) + '" class="hash-link" aria-label="Direct link to ' + escapeHtml(tagName) + ' operations" title="Direct link to ' + escapeHtml(tagName) + ' operations" translate="no">\u200b</a>' +
          '</h3>' +
          '<div class="operation-group__list">' +
          groupedByTag[tagName].map(function (operation) {
            return renderOperationCard(operation, {
              anchorPrefix: 'operation',
              renderModel: renderModel
            });
          }).join('') +
          '</div>' +
          '</section>';
      }).join('');

      if (operationsNavGroup && operationsNavList) {
        operationsNavGroup.hidden = false;
        operationsNavList.innerHTML = orderedTagNames.filter(function (tagName) {
          return groupedByTag[tagName] && groupedByTag[tagName].length;
        }).map(function (tagName) {
          const tagId = slugify(tagName);
          return '<li class="theme-doc-sidebar-item-category theme-doc-sidebar-item-category-level-2 menu__list-item menu__list-item--collapsed">' +
            '<div class="menu__list-item-collapsible">' +
            '<a class="menu__link menu__link--sublist" href="#operations-tag-' + escapeHtml(tagId) + '">' + escapeHtml(tagName) + '</a>' +
            '<button type="button" class="menu__caret" aria-label="Toggle ' + escapeHtml(tagName) + ' operations" aria-expanded="false"></button>' +
            '</div>' +
            '<ul class="menu__list">' +
            groupedByTag[tagName].map(function (operation) {
              const opAnchorId = getOperationAnchorId(operation, 'operation');
              const method = String(operation.method || 'get').toLowerCase();
              const title = operation.summary || operation.id;
              return '<li class="theme-doc-sidebar-item-link theme-doc-sidebar-item-link-level-3 menu__list-item">' +
                '<a class="menu__link menu__link--operation" href="#' + escapeHtml(opAnchorId) + '">' +
                '<span class="menu__link-label">' +
                '<span class="menu__method-badge ' + escapeHtml(method) + '">' + escapeHtml(method) + '</span>' +
                '<span class="menu__link-text">' + escapeHtml(title) + '</span>' +
                '</span>' +
                '</a>' +
                '</li>';
            }).join('') +
            '</ul>' +
            '</li>';
        }).join('');
      }

      refreshCodeExampleCollections();
      refreshVariantCollections();
      bindCodeExampleInteractions();
      bindVariantInteractions();
      bindTryItInteractions();
      refreshNavigationCollections();
      bindNavigationInteractions();
    }

    function hydrateWebhooks(renderModel) {
