      }

      const groupedByName = webhooks.reduce(function (acc, webhook) {
        acc[webhook.name] = acc[webhook.name] || [];
        acc[webhook.name].push(webhook);
        return acc;
      }, {});
      const orderedNames = Object.keys(groupedByName).sort();

      webhooksSection.hidden = false;
      if (webhooksNavItem) {
        webhooksNavItem.hidden = false;
      }

      webhooksGrid.innerHTML = orderedNames.map(function (name) {
        const hookId = slugify(name);
        const items = groupedByName[name];
        return '<section class="webhook-group">' +
          '<h3 class="anchor" id="webhook-group-' + escapeHtml(hookId) + '">' + escapeHtml(name) +
          '<a href="#webhook-group-' + escapeHtml(hookId) + '" class="hash-link" aria-label="Direct link to ' + escapeHtml(name) + ' webhook" title="Direct link to ' + escapeHtml(name) + ' webhook" translate="no">\u200b</a>' +
          '</h3>' +
          '<p class="webhook-group__path"><strong>Webhook event:</strong> <code>' + escapeHtml(name) + '</code></p>' +
