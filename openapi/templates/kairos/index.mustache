<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Kairos API Docs</title>
  {{>styles}}{{! prevent indent}}
</head>
<body>
  <button id="menu-toggle" class="menu-toggle" type="button" aria-expanded="false" aria-controls="sidebar-nav">Menu</button>
  <button id="scroll-to-top" class="scroll-to-top" type="button" aria-label="Navigate to top" title="Navigate to top" hidden>
    <svg viewBox="0 0 24 24" width="18" height="18" focusable="false" aria-hidden="true">
      <path fill="currentColor" d="M12 5.5l6.5 6.5-1.41 1.41L13 9.33V20h-2V9.33l-4.09 4.08L5.5 12z"></path>
    </svg>
  </button>

  <div id="mobile-overlay" class="mobile-overlay"></div>

  <div class="layout">
    {{>sidebar}}{{! prevent indent}}
    {{>main-content}}{{! prevent indent}}
  </div>

  {{>behavior}}{{! prevent indent}}
</body>
</html>
