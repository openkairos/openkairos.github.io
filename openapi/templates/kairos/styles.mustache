<style>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&display=swap');

  :root {
    --ifm-color-primary: #ff343a;
    --ifm-color-primary-dark: #e62f34;
    --ifm-color-primary-darker: #d92c31;
    --ifm-color-primary-light: #ff4c52;
    --ifm-link-color: #d92c31;
    --ifm-color-emphasis-100: #f5f6f7;
    --ifm-color-emphasis-200: #ebedf0;
    --ifm-color-emphasis-300: #dadde1;
    --ifm-color-emphasis-700: #606770;
    --ifm-color-emphasis-900: #1c1e21;
    --ifm-background-color: #ffffff;
    --ifm-font-family-base: 'Manrope', sans-serif;
    --ifm-font-family-monospace: 'Fira Code', monospace;
    --ifm-font-weight-semibold: 600;
    --ifm-transition-fast: 200ms;
    --ifm-transition-timing-default: ease;
    --ifm-menu-color: #444950;
    --ifm-menu-color-active: var(--ifm-color-primary-darker);
    --ifm-menu-color-background-active: rgba(217, 44, 49, 0.1);
    --ifm-menu-color-background-hover: var(--ifm-color-emphasis-100);
    --ifm-menu-link-padding-vertical: 0.375rem;
    --ifm-menu-link-padding-horizontal: 0.75rem;
    --ifm-navbar-height: 3.75rem;
    --ifm-toc-border-color: var(--ifm-color-emphasis-200);
    --ifm-scrollbar-size: 7px;
    --ifm-scrollbar-track-background-color: #f1f2f4;
    --ifm-scrollbar-thumb-background-color: #c3c7ce;
    --ifm-scrollbar-thumb-hover-background-color: #a4acb8;
    --doc-sidebar-width: 320px;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    font-family: var(--ifm-font-family-base);
    background: var(--ifm-background-color);
    color: var(--ifm-color-emphasis-900);
  }

  body.nav-open {
    overflow: hidden;
  }

  .menu-toggle {
    display: none;
    position: fixed;
    top: 14px;
    right: 14px;
    z-index: 12;
    border: 1px solid var(--ifm-color-emphasis-300);
    background: #fff;
    color: var(--ifm-color-emphasis-900);
    border-radius: 10px;
    padding: 8px 12px;
    font: inherit;
    font-weight: 600;
  }

  .scroll-to-top {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 11;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(217, 44, 49, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    color: var(--ifm-color-primary-darker);
    box-shadow: 0 10px 30px rgba(17, 24, 39, 0.12);
    cursor: pointer;
    transition: opacity var(--ifm-transition-fast) ease, transform var(--ifm-transition-fast) ease, box-shadow var(--ifm-transition-fast) ease;
  }

  .scroll-to-top[hidden] {
    display: none;
  }

  .scroll-to-top:hover,
  .scroll-to-top:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 14px 34px rgba(17, 24, 39, 0.16);
    outline: none;
  }

  .layout {
    display: grid;
    grid-template-columns: var(--doc-sidebar-width) 1fr;
    min-height: 100vh;
  }

  .docSidebarContainer {
    border-right: 1px solid var(--ifm-color-emphasis-200);
    background: #fcfcfd;
    width: var(--doc-sidebar-width);
    transition: width var(--ifm-transition-fast) ease;
    clip-path: inset(0);
  }

  .sidebarViewport {
    position: sticky;
    top: 0;
    height: 100vh;
    max-height: 100vh;
    overflow-y: auto;
    padding: 16px 10px 20px;
  }

  .menu {
    font-weight: var(--ifm-font-weight-semibold);
    overflow-x: hidden;
  }

  .menu__list {
    list-style: none;
    margin: 0;
    padding-left: 0;
  }

  .menu__list .menu__list {
    flex: 0 0 100%;
    margin-top: 0.25rem;
    padding-left: var(--ifm-menu-link-padding-horizontal);
  }

  .menu__list-item:not(:first-child) {
    margin-top: 0.25rem;
  }

  .menu__list-item--collapsed .menu__list {
    height: 0;
    overflow: hidden;
  }

  .menu__list-item--collapsed .menu__caret:before {
    transform: rotate(90deg);
  }

  .menu__list-item-collapsible {
    border-radius: 0.25rem;
    display: flex;
    flex-wrap: wrap;
    position: relative;
    transition: background var(--ifm-transition-fast) var(--ifm-transition-timing-default);
  }

  .menu__list-item-collapsible:hover {
    background: var(--ifm-menu-color-background-hover);
  }

  .menu__list-item-collapsible .menu__link--active,
  .menu__list-item-collapsible .menu__link:hover {
    background: none !important;
  }

  .menu__link,
  .menu__caret {
    align-items: center;
    border-radius: 0.25rem;
    display: flex;
    transition: background var(--ifm-transition-fast) var(--ifm-transition-timing-default);
  }

  .menu__link:hover,
  .menu__caret:hover {
    background: var(--ifm-menu-color-background-hover);
  }

  .menu__link:focus-visible,
  .menu__caret:focus-visible,
  .variant-tab:focus-visible,
  .code-tab:focus-visible,
  .copy-example-btn:focus-visible,
  .json-tree__summary:focus-visible,
  .operation-card__details-summary:focus-visible,
  .try-it-panel__optional-summary:focus-visible,
  .try-it-shell__summary:focus-visible,
  .auth-item__summary:focus-visible {
    outline: 0;
    box-shadow: 0 0 0 3px rgba(217, 44, 49, 0.16);
  }

  .menu__link {
    color: var(--ifm-menu-color);
    flex: 1;
    line-height: 1.25;
    padding: var(--ifm-menu-link-padding-vertical) var(--ifm-menu-link-padding-horizontal);
    border: 0;
    background: none;
    font: inherit;
    text-align: left;
    cursor: pointer;
    text-decoration: none;
    font-size: 0.93rem;
    min-height: 32px;
  }

  .menu__link:hover {
    color: var(--ifm-menu-color);
    text-decoration: none;
  }

  .menu__link--active,
  .menu__link--active:hover {
    color: var(--ifm-menu-color-active);
  }

  .menu__link--active:not(.menu__link--sublist) {
    background-color: var(--ifm-menu-color-background-active);
  }

  .menu__link--operation {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 6px;
    padding-top: 9px;
    padding-bottom: 9px;
  }

  .menu__link-label {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }

  .menu__link-text {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .menu__link-meta {
    display: block;
    min-width: 0;
    overflow: hidden;
    color: var(--ifm-color-emphasis-700);
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: var(--ifm-font-family-monospace);
    font-size: 0.78rem;
    font-weight: 500;
  }

  .menu__link--active .menu__link-meta {
    color: var(--ifm-menu-color-active);
  }

  .menu__method-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 52px;
    border-radius: 999px;
    padding: 3px 8px;
    color: #fff;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
    flex: 0 0 auto;
  }

  .menu__method-badge.get { background: #2e8555; }
  .menu__method-badge.post { background: #3578e5; }
  .menu__method-badge.put { background: #8b5cf6; }
  .menu__method-badge.patch { background: #f08c00; }
  .menu__method-badge.delete { background: #d93939; }
  .menu__method-badge.options { background: #6b7280; }
  .menu__method-badge.head { background: #4b5563; }
  .menu__method-badge.trace { background: #0f766e; }

  .menu__caret {
    background: none;
    border: 0;
    cursor: pointer;
    padding: var(--ifm-menu-link-padding-vertical) var(--ifm-menu-link-padding-horizontal);
  }

  .menu__caret:before {
    content: "";
    width: 1.25rem;
    height: 1.25rem;
    opacity: 0.7;
    transform: rotate(180deg);
    transition: transform var(--ifm-transition-fast) linear;
    background: currentColor;
    clip-path: polygon(25% 32%, 50% 58%, 75% 32%, 82% 39%, 50% 72%, 18% 39%);
  }

  .content {
    overflow-x: hidden;
    padding: 28px clamp(20px, 4vw, 56px) 72px;
    max-width: none;
    width: 100%;
  }

  .eyebrow {
    margin: 0 0 6px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--ifm-color-primary-darker);
  }

  .doc-overview__topbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 6px;
  }

  h1 {
    margin: 0;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.1;
  }

  .lead {
    margin: 14px 0 24px;
    font-size: 17px;
    line-height: 1.6;
    color: #4f5d75;
  }

  .doc-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 20px;
  }

  .doc-meta__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--ifm-color-emphasis-200);
    border-radius: 999px;
    background: #f8f9fb;
    padding: 7px 12px 7px 9px;
    font-size: 13px;
    color: #3d4652;
  }

  .doc-meta__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: rgba(217, 44, 49, 0.1);
    color: var(--ifm-color-primary-darker);
    flex: 0 0 auto;
  }

  .doc-meta__link {
    color: var(--ifm-link-color);
    text-decoration: none;
    font-weight: 600;
  }

  .doc-meta__link:hover,
  .doc-meta__link:focus,
  .doc-meta__link:visited {
    color: var(--ifm-link-color);
    text-decoration: underline;
  }

  .doc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 24px;
  }

  .doc-actions--top {
    margin: 0;
    justify-content: flex-end;
    flex: 0 0 auto;
  }

  .ui-btn,
  .doc-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid var(--ifm-color-emphasis-300);
    border-radius: 12px;
    background: #fff;
    color: #253247;
    font-weight: 700;
    font: inherit;
    text-decoration: none;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .ui-btn {
    min-height: 36px;
    padding: 8px 12px;
    font-size: 13px;
    line-height: 1.2;
  }

  .ui-btn--sm {
    min-height: 34px;
    padding: 7px 11px;
    font-size: 12px;
  }

  .ui-btn--ghost {
    background: #fff;
    color: #253247;
  }

  .ui-btn--accent {
    border-color: rgba(217, 44, 49, 0.22);
    background: rgba(217, 44, 49, 0.08);
    color: var(--ifm-color-primary-darker);
  }

  .ui-btn:hover,
  .ui-btn:focus,
  .doc-action-btn:hover,
  .doc-action-btn:focus {
    border-color: var(--ifm-color-primary-darker);
    color: var(--ifm-color-primary-darker);
    text-decoration: none;
    box-shadow: 0 0 0 3px rgba(217, 44, 49, 0.12);
  }

  .ui-btn--accent:hover,
  .ui-btn--accent:focus {
    background: rgba(217, 44, 49, 0.12);
  }

  .doc-action-btn {
    min-height: 42px;
    padding: 10px 14px;
    font-size: 14px;
  }

  .operations-stack {
    display: grid;
    gap: 24px;
  }

  .webhooks-stack {
    display: grid;
    gap: 20px;
  }

  .components-stack {
    display: grid;
    gap: 24px;
  }

  .operation-group {
    display: grid;
    gap: 14px;
  }

  .operation-group > h3 {
    margin: 0;
    font-size: 22px;
    line-height: 1.25;
  }

  .operation-group__list {
    display: grid;
    gap: 16px;
  }

  .webhook-group {
    display: grid;
    gap: 14px;
  }

  .webhook-group > h3 {
    margin: 0;
    font-size: 22px;
    line-height: 1.25;
  }

  .webhook-group__path {
    margin: -4px 0 0;
    color: #5e6879;
    font-size: 14px;
    line-height: 1.5;
  }

  .webhook-group__list {
    display: grid;
    gap: 16px;
  }

  .component-group {
    display: grid;
    gap: 14px;
  }

  .component-group > h3 {
    margin: 0;
    font-size: 22px;
    line-height: 1.25;
  }

  .component-group__meta {
    margin: -4px 0 0;
    color: #5e6879;
    font-size: 14px;
    line-height: 1.5;
  }

  .component-group__list {
    display: grid;
    gap: 16px;
  }

  .component-card__meta {
    margin: 0 0 10px;
    color: #5e6879;
    line-height: 1.6;
  }

  .component-card__meta code {
    font-size: 12px;
  }

  .component-card__description {
    margin: 0 0 12px;
    color: #4f5d75;
    line-height: 1.65;
  }

  .operation-card h4 {
    margin: 0 0 10px;
    font-size: 20px;
    line-height: 1.3;
  }

  .operation-card {
    padding: 24px;
  }

  .operation-card__text {
    margin: 0 0 12px;
    color: #4f5d75;
    line-height: 1.65;
  }

  .operation-card__summary {
    display: grid;
    gap: 8px;
    margin-bottom: 18px;
  }

  .operation-card__meta-line {
    margin: 0;
    color: #5e6879;
    line-height: 1.6;
  }

  .operation-card__workspace {
    margin-bottom: 18px;
    padding: 14px;
    border: 1px solid rgba(217, 44, 49, 0.12);
    border-radius: 16px;
    background:
      radial-gradient(circle at top left, rgba(255, 52, 58, 0.06), transparent 34%),
      linear-gradient(180deg, #fffdfd 0%, #ffffff 100%);
  }

  .operation-card__details {
    display: grid;
    gap: 12px;
    border: 1px solid var(--ifm-color-emphasis-200);
    border-radius: 14px;
    background: #fbfbfc;
    overflow: hidden;
  }

  .operation-card__details + .operation-card__details {
    margin-top: 14px;
  }

  .operation-card__details-summary {
    list-style: none;
    cursor: pointer;
    padding: 18px;
  }

  .operation-card__details-summary::-webkit-details-marker {
    display: none;
  }

  .operation-card__details-summary::marker {
    content: "";
  }

  .operation-card__details-summary .operation-card__section-header {
    position: relative;
    padding-right: 28px;
  }

  .operation-card__details-summary .operation-card__section-header::after {
    content: "";
    position: absolute;
    top: 50%;
    right: 0;
    width: 16px;
    height: 16px;
    background: currentColor;
    color: #6b7587;
    transform: translateY(-50%) rotate(0deg);
    transition: transform 0.2s ease;
    clip-path: polygon(20% 35%, 50% 65%, 80% 35%, 88% 43%, 50% 81%, 12% 43%);
  }

  .operation-card__details[open] .operation-card__details-summary .operation-card__section-header::after {
    transform: translateY(-50%) rotate(180deg);
  }

  .operation-card__details-body {
    display: grid;
    gap: 12px;
    padding: 0 18px 18px;
  }

  .operation-card__section-header {
    display: grid;
    gap: 6px;
  }

  .operation-card__section-header h5 {
    margin: 0;
    font-size: 15px;
    line-height: 1.35;
  }

  .operation-card__section-header p {
    margin: 0;
    color: #5e6879;
    font-size: 13px;
    line-height: 1.55;
  }

  .operation-content-card,
  .operation-response-card {
    margin-top: 0;
    margin-bottom: 0;
    padding: 16px;
    background: #fdfdfe;
  }

  .operation-content-card h4,
  .operation-response-card h4 {
    margin: 0 0 10px;
    font-size: 16px;
    line-height: 1.35;
  }

  .json-tree {
    margin-top: 12px;
    border: 1px solid var(--ifm-color-emphasis-200);
    border-radius: 12px;
    background: #fff;
    overflow: hidden;
  }

  .json-raw {
    margin-top: 12px;
    border: 0;
    border-radius: 0;
    background: transparent;
    overflow: visible;
  }

  .json-raw__header {
    padding: 0 0 8px;
    color: #253247;
    font-size: 13px;
    font-weight: 700;
  }

  .json-raw__body {
    margin: 0;
    padding: 14px;
    background: #f4f6fa;
    color: #1f2937;
    font-family: var(--ifm-font-family-monospace);
    font-size: 13px;
    line-height: 1.65;
    overflow-x: auto;
    border: 1px solid var(--ifm-color-emphasis-200);
    border-radius: 12px;
  }

  .json-raw__body code {
    color: inherit;
    background: transparent;
    padding: 0;
  }

  .json-tree__summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px;
    color: #253247;
    font-size: 13px;
    font-weight: 700;
  }

  .json-tree__summary::-webkit-details-marker {
    display: none;
  }

  .json-tree__summary::marker {
    content: "";
  }

  .json-tree__summary::before {
    content: "";
    width: 14px;
    height: 14px;
    margin-right: 8px;
    background: currentColor;
    color: #6b7587;
    transform: rotate(0deg);
    transition: transform 0.2s ease;
    clip-path: polygon(20% 35%, 50% 65%, 80% 35%, 88% 43%, 50% 81%, 12% 43%);
    flex: 0 0 auto;
  }

  .json-tree[open] > .json-tree__summary::before,
  .json-tree__node[open] > .json-tree__summary::before {
    transform: rotate(180deg);
  }

  .json-tree__summary--root {
    background: linear-gradient(180deg, #fff7f7 0%, #f8f9fb 100%);
    border-bottom: 1px solid var(--ifm-color-emphasis-200);
  }

  .json-tree__title,
  .json-tree__key {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .json-tree__meta {
    margin-left: auto;
    color: #6b7587;
    font-size: 12px;
    font-weight: 600;
  }

  .json-tree__children {
    display: grid;
    gap: 8px;
    padding: 0 14px 14px;
  }

  .json-tree__children--root {
    padding-top: 14px;
    background: #fff;
  }

  .json-tree__node {
    border-left: 1px solid var(--ifm-color-emphasis-200);
    padding-left: 12px;
  }

  .json-tree__node > .json-tree__summary {
    padding: 8px 0;
  }

  .json-tree__node > .json-tree__children {
    padding: 0 0 0 10px;
  }

  .json-tree__leaf {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    align-items: start;
    padding: 6px 0;
  }

  .json-tree__value {
    white-space: nowrap;
  }

  .json-tree__empty {
    color: #6b7587;
    font-size: 12px;
    padding: 4px 0 0;
  }

  .operation-responses {
    display: grid;
    gap: 12px;
    margin-top: 0;
  }

  .try-it-panel {
    border: 1px solid var(--ifm-color-emphasis-200);
    border-radius: 12px;
    background: #fff;
    overflow: hidden;
    height: 100%;
    box-shadow: 0 12px 32px rgba(28, 30, 33, 0.04);
  }

  .try-it-panel__header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--ifm-color-emphasis-200);
    background:
      linear-gradient(135deg, rgba(255, 52, 58, 0.08), rgba(255, 255, 255, 0) 55%),
      #f8f9fb;
  }

  .try-it-panel__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .try-it-panel__header h3 {
    margin: 0;
    font-size: 14px;
    line-height: 1.25;
  }

  .try-it-panel__hint {
    margin: 4px 0 0;
    color: #5e6879;
    font-size: 13px;
    line-height: 1.5;
  }

  .try-it-panel__status {
    padding: 12px 14px;
    color: #4f5d75;
    font-size: 13px;
    line-height: 1.5;
    border-top: 1px solid var(--ifm-color-emphasis-200);
  }

  .try-it-panel__editor {
    display: grid;
    gap: 14px;
    padding: 14px;
    border-bottom: 1px solid var(--ifm-color-emphasis-200);
    background: #fff;
  }

  .try-it-panel__editor:empty {
    display: none;
  }

  .try-it-panel__preview {
    display: grid;
    gap: 10px;
    padding: 14px;
    border-bottom: 1px solid var(--ifm-color-emphasis-200);
    background: #fff;
  }

  .try-it-panel__preview-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
